@@ -0,0 +1,206 @@
+'use client'
+import { useState, useEffect, useCallback } from 'react'
+import { useParams } from 'next/navigation'
+import { RangeKey } from '@/components/portal/RangeFilter'
+import ConsentRecordsSummary, { RecordsSummary } from '@/components/portal/ConsentRecordsSummary'
+import ConsentRecordsFilters, { StatusOption, PurposeOption } from '@/components/portal/ConsentRecordsFilters'
+import ConsentLedgerTable, { LedgerRecord } from '@/components/portal/ConsentLedgerTable'
+import Pagination from '@/components/portal/Pagination'
+import ConsentRecordDrawer from '@/components/portal/ConsentRecordDrawer'
+import ExportMenu from '@/components/portal/ExportMenu'
+import { LEDGER_EVENT_TYPES } from '@/lib/consent-records'
+
+export default function ConsentRecordsPage() {
+  const { clientKey } = useParams<{ clientKey: string }>()
+
+  const [range, setRange] = useState<RangeKey>('30d')
+  const [from, setFrom] = useState('')
+  const [to, setTo] = useState('')
+  const [statuses, setStatuses] = useState<string[]>([...LEDGER_EVENT_TYPES])
+  const [purpose, setPurpose] = useState('')
+  const [language, setLanguage] = useState('')
+  const [search, setSearch] = useState('')
+  const [sortBy, setSortBy] = useState('created_at')
+  const [sortDir, setSortDir] = useState<'asc' | 'desc'>('desc')
+  const [page, setPage] = useState(1)
+  const [pageSize, setPageSize] = useState(25)
+
+  const [records, setRecords] = useState<LedgerRecord[]>([])
+  const [count, setCount] = useState(0)
+  const [summary, setSummary] = useState<RecordsSummary | null>(null)
+  const [statusOptions, setStatusOptions] = useState<StatusOption[]>([])
+  const [purposeOptions, setPurposeOptions] = useState<PurposeOption[]>([])
+  const [languageOptions, setLanguageOptions] = useState<string[]>([])
+  const [loading, setLoading] = useState(true)
+  const [error, setError] = useState<string | null>(null)
+  const [selected, setSelected] = useState<Set<string>>(new Set())
+  const [drawerId, setDrawerId] = useState<string | null>(null)
+
+  const buildParams = useCallback(() => {
+    const params = new URLSearchParams({ key: String(clientKey), range })
+    if (range === 'custom') {
+      if (from) params.set('from', from)
+      if (to) params.set('to', to)
+    }
+    if (statuses.length > 0 && statuses.length < LEDGER_EVENT_TYPES.length) params.set('status', statuses.join(','))
+    if (purpose) params.set('purpose', purpose)
+    if (language) params.set('language', language)
+    if (search) params.set('search', search)
+    return params
+  }, [clientKey, range, from, to, statuses, purpose, language, search])
+
+  const load = useCallback(() => {
+    const params = buildParams()
+    params.set('sortBy', sortBy)
+    params.set('sortDir', sortDir)
+    params.set('page', String(page))
+    params.set('pageSize', String(pageSize))
+
+    return fetch(`/api/dashboard/consent-records?${params.toString()}`)
+      .then((r) => r.json())
+      .then((d) => {
+        if (d.error) throw new Error(d.error)
+        setRecords(d.records)
+        setCount(d.count)
+        setSummary(d.summary)
+        setStatusOptions(d.filters.statuses)
+        setPurposeOptions(d.filters.purposes)
+        setLanguageOptions(d.filters.languages)
+        setError(null)
+      })
+      .catch(() => setError('Could not load consent records. Try again shortly.'))
+      .finally(() => setLoading(false))
+  }, [buildParams, sortBy, sortDir, page, pageSize])
+
+  useEffect(() => {
+    load()
+  }, [load])
+
+  function resetForRefetch() {
+    setLoading(true)
+    setError(null)
+    setSelected(new Set())
+  }
+
+  function handleRangeChange(r: RangeKey, f?: string, t?: string) {
+    const nextFrom = f ?? from
+    setRange(r)
+    if (f !== undefined) setFrom(f)
+    if (t !== undefined) setTo(t)
+    if (r === 'custom' && !nextFrom) return
+    setPage(1)
+    resetForRefetch()
+  }
+
+  function toggleStatus(status: string) {
+    setStatuses((prev) => (prev.includes(status) ? prev.filter((s) => s !== status) : [...prev, status]))
+    setPage(1)
+    resetForRefetch()
+  }
+
+  function handlePurposeChange(p: string) {
+    setPurpose(p)
+    setPage(1)
+    resetForRefetch()
+  }
+
+  function handleLanguageChange(l: string) {
+    setLanguage(l)
+    setPage(1)
+    resetForRefetch()
+  }
+
+  function handleSearchChange(s: string) {
+    setSearch(s)
+    setPage(1)
+    resetForRefetch()
+  }
+
+  function handleSort(col: string) {
+    if (sortBy === col) {
+      setSortDir((d) => (d === 'asc' ? 'desc' : 'asc'))
+    } else {
+      setSortBy(col)
+      setSortDir('desc')
+    }
+    setLoading(true)
+  }
+
+  function handlePageChange(p: number) {
+    setPage(p)
+    setLoading(true)
+  }
+
+  function handlePageSizeChange(size: number) {
+    setPageSize(size)
+    setPage(1)
+    setLoading(true)
+  }
+
+  function toggleSelect(id: string) {
+    setSelected((prev) => {
+      const next = new Set(prev)
+      if (next.has(id)) next.delete(id)
+      else next.add(id)
+      return next
+    })
+  }
+
+  function toggleSelectAll() {
+    setSelected((prev) => {
+      if (records.every((r) => prev.has(r.id))) return new Set()
+      return new Set(records.map((r) => r.id))
+    })
+  }
+
+  return (
+    <div className="p-8">
+      <div className="mb-6 flex items-start justify-between gap-4 flex-wrap">
+        <div>
+          <h1 className="text-2xl font-bold text-[#1b1b29] tracking-tight">Consent Records</h1>
+          <p className="text-sm text-zinc-500 mt-1">Complete audit trail of consent decisions for compliance and reporting</p>
+        </div>
+        <ExportMenu
+          clientKey={String(clientKey)}
+          baseParams={buildParams()}
+          selectedCount={selected.size}
+          buildSelectedIds={() => Array.from(selected)}
+        />
+      </div>
+
+      {error && (
+        <div className="bg-red-500/5 border border-red-500/20 rounded-2xl p-4 mb-6 text-sm text-red-500">{error}</div>
+      )}
+
+      <ConsentRecordsSummary summary={summary} loading={loading} />
+
+      <ConsentRecordsFilters
+        range={range} from={from} to={to} onRangeChange={handleRangeChange}
+        statusOptions={statusOptions} selectedStatuses={statuses} onStatusToggle={toggleStatus}
+        purposeOptions={purposeOptions} purpose={purpose} onPurposeChange={handlePurposeChange}
+        languageOptions={languageOptions} language={language} onLanguageChange={handleLanguageChange}
+        search={search} onSearchChange={handleSearchChange}
+      />
+
+      <ConsentLedgerTable
+        records={records}
+        loading={loading}
+        sortBy={sortBy}
+        sortDir={sortDir}
+        onSort={handleSort}
+        selected={selected}
+        onToggleSelect={toggleSelect}
+        onToggleSelectAll={toggleSelectAll}
+        onRowClick={setDrawerId}
+      />
+
+      {!loading && records.length > 0 && (
+        <Pagination page={page} pageSize={pageSize} count={count} onPageChange={handlePageChange} onPageSizeChange={handlePageSizeChange} />
+      )}
+
+      {drawerId && (
+        <ConsentRecordDrawer clientKey={String(clientKey)} recordId={drawerId} onClose={() => setDrawerId(null)} />
+      )}
+    </div>
+  )
+}
diff --git a/src/components/portal/ConsentLedgerTable.tsx b/src/components/portal/ConsentLedgerTable.tsx
