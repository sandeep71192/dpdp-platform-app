@@ -0,0 +1,102 @@
+'use client'
+import { useEffect, useState } from 'react'
+import { languageName } from '@/lib/lang-names'
+
+interface PurposeSelection {
+  purpose: string
+  label: string
+  accepted: boolean
+}
+
+interface RecordDetail {
+  id: string
+  consentId: string
+  timestamp: string
+  language: string | null
+  status: string
+  statusLabel: string
+  statusEmoji: string
+  widgetVersion: number | null
+  purposeSelection: PurposeSelection[]
+  sourceWebsite: string | null
+  consentMethod: string
+  deviceType: string | null
+  country: string | null
+  sessionId: string | null
+}
+
+export default function ConsentRecordDrawer({ clientKey, recordId, onClose }: { clientKey: string; recordId: string; onClose: () => void }) {
+  const [detail, setDetail] = useState<RecordDetail | null>(null)
+  const [loading, setLoading] = useState(true)
+  const [error, setError] = useState<string | null>(null)
+
+  useEffect(() => {
+    fetch(`/api/dashboard/consent-records/${recordId}?key=${clientKey}`)
+      .then((r) => r.json())
+      .then((d) => { if (d.record) setDetail(d.record); else setError('Could not load record details.') })
+      .catch(() => setError('Could not load record details.'))
+      .finally(() => setLoading(false))
+  }, [clientKey, recordId])
+
+  return (
+    <div className="fixed inset-0 z-50 flex justify-end">
+      <div className="absolute inset-0 bg-black/20" onClick={onClose} />
+      <div className="relative w-full max-w-md bg-[#f7f6f3] h-full overflow-y-auto border-l border-[#e8e8ee] shadow-xl">
+        <div className="sticky top-0 bg-[#ffffff] border-b border-[#e8e8ee] px-6 py-4 flex items-center justify-between">
+          <h2 className="text-sm font-bold text-[#1b1b29]">Consent Record</h2>
+          <button onClick={onClose} className="text-zinc-400 hover:text-[#1b1b29] text-lg leading-none">✕</button>
+        </div>
+
+        <div className="p-6">
+          {loading ? (
+            <div className="space-y-3">
+              {[0, 1, 2, 3].map((i) => <div key={i} className="h-10 bg-black/[0.04] rounded animate-pulse" />)}
+            </div>
+          ) : error || !detail ? (
+            <div className="text-sm text-red-500">{error || 'Record not found.'}</div>
+          ) : (
+            <div className="space-y-5">
+              <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4 space-y-2">
+                <Row label="Consent ID" value={detail.consentId} mono />
+                <Row label="Timestamp" value={new Date(detail.timestamp).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'medium', timeZone: 'Asia/Kolkata' }) + ' IST'} />
+                <Row label="Status" value={`${detail.statusEmoji} ${detail.statusLabel}`} />
+                <Row label="Language" value={detail.language ? languageName(detail.language) : '—'} />
+                <Row label="Widget Version" value={detail.widgetVersion !== null ? `v${detail.widgetVersion}` : '—'} />
+                <Row label="Source Website" value={detail.sourceWebsite || '—'} mono />
+                <Row label="Consent Method" value={detail.consentMethod} />
+                <Row label="Device Type" value={detail.deviceType || '—'} />
+                <Row label="Country" value={detail.country || '—'} />
+                <Row label="Session ID" value={detail.sessionId || '—'} mono />
+              </div>
+
+              <div>
+                <h3 className="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Purpose Selection</h3>
+                {detail.purposeSelection.length === 0 ? (
+                  <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4 text-sm text-zinc-500">No purpose-level data recorded for this event.</div>
+                ) : (
+                  <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl divide-y divide-[#e8e8ee]">
+                    {detail.purposeSelection.map((p) => (
+                      <div key={p.purpose} className="flex items-center justify-between px-4 py-2.5">
+                        <span className="text-sm text-zinc-700">{p.label}</span>
+                        <span className={`text-sm font-semibold ${p.accepted ? 'text-green-600' : 'text-red-500'}`}>{p.accepted ? '✓' : '✗'}</span>
+                      </div>
+                    ))}
+                  </div>
+                )}
+              </div>
+            </div>
+          )}
+        </div>
+      </div>
+    </div>
+  )
+}
+
+function Row({ label, value, mono }: { label: string; value: string; mono?: boolean }) {
+  return (
+    <div className="flex items-start justify-between gap-3 text-sm">
+      <span className="text-zinc-500">{label}</span>
+      <span className={`text-right text-[#1b1b29] font-medium ${mono ? 'font-mono text-xs' : ''} break-all`}>{value}</span>
+    </div>
+  )
+}
diff --git a/src/components/portal/ConsentRecordsFilters.tsx b/src/components/portal/ConsentRecordsFilters.tsx
