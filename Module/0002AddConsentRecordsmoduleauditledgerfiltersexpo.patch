+export interface RecordsSummary {
+  total: number
+  accepted: number
+  rejected: number
+  customized: number
+  withdrawn: number
+}
+
+const CARDS: { key: keyof RecordsSummary; label: string; emoji: string; color: string }[] = [
+  { key: 'total', label: 'Total Records', emoji: '📄', color: 'text-[#1b1b29]' },
+  { key: 'accepted', label: 'Accepted', emoji: '🟢', color: 'text-green-600' },
+  { key: 'rejected', label: 'Rejected', emoji: '🔴', color: 'text-red-500' },
+  { key: 'customized', label: 'Customized', emoji: '🟡', color: 'text-amber-500' },
+  { key: 'withdrawn', label: 'Withdrawn', emoji: '⚫', color: 'text-zinc-500' },
+]
+
+export default function ConsentRecordsSummary({ summary, loading }: { summary: RecordsSummary | null; loading: boolean }) {
+  return (
+    <div className="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
+      {CARDS.map((c) => (
+        <div key={c.key} className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4">
+          <div className="text-xs text-zinc-500 mb-1">{c.emoji} {c.label}</div>
+          {loading && !summary ? (
+            <div className="h-7 w-12 bg-black/[0.04] rounded animate-pulse" />
+          ) : (
+            <div className={`text-2xl font-bold ${c.color}`}>{(summary?.[c.key] ?? 0).toLocaleString()}</div>
+          )}
+        </div>
+      ))}
+    </div>
+  )
