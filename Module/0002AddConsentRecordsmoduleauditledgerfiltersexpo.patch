@@ -0,0 +1,119 @@
+'use client'
+import { useState } from 'react'
+import RangeFilter, { RangeKey } from './RangeFilter'
+import { languageName } from '@/lib/lang-names'
+
+export interface StatusOption {
+  value: string
+  label: string
+  emoji: string
+}
+
+export interface PurposeOption {
+  value: string
+  label: string
+}
+
+interface FiltersProps {
+  range: RangeKey
+  from: string
+  to: string
+  onRangeChange: (range: RangeKey, from?: string, to?: string) => void
+  statusOptions: StatusOption[]
+  selectedStatuses: string[]
+  onStatusToggle: (status: string) => void
+  purposeOptions: PurposeOption[]
+  purpose: string
+  onPurposeChange: (purpose: string) => void
+  languageOptions: string[]
+  language: string
+  onLanguageChange: (language: string) => void
+  search: string
+  onSearchChange: (search: string) => void
+}
+
+export default function ConsentRecordsFilters({
+  range, from, to, onRangeChange,
+  statusOptions, selectedStatuses, onStatusToggle,
+  purposeOptions, purpose, onPurposeChange,
+  languageOptions, language, onLanguageChange,
+  search, onSearchChange,
+}: FiltersProps) {
+  const [searchInput, setSearchInput] = useState(search)
+
+  return (
+    <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4 mb-6 space-y-3">
+      <div className="flex items-start justify-between gap-4 flex-wrap">
+        <RangeFilter range={range} from={from} to={to} onChange={onRangeChange} />
+        <form
+          onSubmit={(e) => { e.preventDefault(); onSearchChange(searchInput) }}
+          className="flex items-center gap-2"
+        >
+          <input
+            type="text"
+            value={searchInput}
+            onChange={(e) => setSearchInput(e.target.value)}
+            placeholder="Search by Consent ID, Session ID…"
+            className="text-xs px-3 py-1.5 rounded-lg border border-[#e8e8ee] bg-white text-zinc-700 w-56"
+          />
+          <button type="submit" className="text-xs px-3 py-1.5 rounded-lg bg-violet-600 text-white font-medium hover:bg-violet-500 transition-colors">
+            Search
+          </button>
+          {search && (
+            <button
+              type="button"
+              onClick={() => { setSearchInput(''); onSearchChange('') }}
+              className="text-xs px-3 py-1.5 rounded-lg bg-black/[0.04] text-zinc-500 hover:text-[#1b1b29] font-medium transition-colors"
+            >
+              Clear
+            </button>
+          )}
+        </form>
+      </div>
+
+      <div className="flex items-center gap-4 flex-wrap">
+        <div className="flex items-center gap-1.5 flex-wrap">
+          <span className="text-xs text-zinc-500 mr-1">Status:</span>
+          {statusOptions.map((s) => {
+            const active = selectedStatuses.includes(s.value)
+            return (
+              <button
+                key={s.value}
+                onClick={() => onStatusToggle(s.value)}
+                className={`text-xs px-2.5 py-1 rounded-lg font-medium transition-colors ${active ? 'bg-violet-500/10 text-violet-600 border border-violet-500/30' : 'bg-black/[0.04] text-zinc-500 hover:text-[#1b1b29] border border-transparent'}`}
+              >
+                {s.emoji} {s.label}
+              </button>
+            )
+          })}
+        </div>
+
+        {purposeOptions.length > 0 && (
+          <select
+            value={purpose}
+            onChange={(e) => onPurposeChange(e.target.value)}
+            className="text-xs px-2.5 py-1.5 rounded-lg border border-[#e8e8ee] bg-white text-zinc-700"
+          >
+            <option value="">All Purposes</option>
+            {purposeOptions.map((p) => (
+              <option key={p.value} value={p.value}>{p.label}</option>
+            ))}
+          </select>
+        )}
+
+        {languageOptions.length > 0 && (
+          <select
+            value={language}
+            onChange={(e) => onLanguageChange(e.target.value)}
+            className="text-xs px-2.5 py-1.5 rounded-lg border border-[#e8e8ee] bg-white text-zinc-700"
+          >
+            <option value="">All Languages</option>
+            {languageOptions.map((l) => (
+              <option key={l} value={l}>{languageName(l)}</option>
+            ))}
+          </select>
+        )}
+      </div>
+    </div>
+  )
