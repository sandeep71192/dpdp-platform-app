+'use client'
+import { useState } from 'react'
+
+interface ExportMenuProps {
+  clientKey: string
+  baseParams: URLSearchParams
+  selectedCount: number
+  buildSelectedIds: () => string[]
+}
+
+const FORMATS = [
+  { value: 'csv', label: 'CSV' },
+  { value: 'xlsx', label: 'Excel (.xlsx)' },
+  { value: 'pdf', label: 'PDF' },
+]
+
+const SCOPES = (selectedCount: number) => [
+  { value: 'filtered', label: 'Current Filtered Results' },
+  { value: 'selected', label: `Selected Records (${selectedCount})`, disabled: selectedCount === 0 },
+  { value: 'all', label: 'All Records' },
+  { value: 'range', label: 'Date Range Export' },
+]
+
+export default function ExportMenu({ clientKey, baseParams, selectedCount, buildSelectedIds }: ExportMenuProps) {
+  const [open, setOpen] = useState(false)
+  const [format, setFormat] = useState('csv')
+  const [scope, setScope] = useState('filtered')
+
+  function handleExport() {
+    const params = new URLSearchParams(baseParams)
+    params.set('key', clientKey)
+    params.set('format', format)
+    params.set('scope', scope)
+    if (scope === 'selected') {
+      params.set('ids', buildSelectedIds().join(','))
+    }
+    window.open(`/api/dashboard/consent-records/export?${params.toString()}`, '_blank')
+    setOpen(false)
+  }
+
+  return (
+    <div className="relative">
+      <button
+        onClick={() => setOpen((o) => !o)}
+        className="px-4 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-xl transition-colors"
+      >
+        ⬇️ Export
+      </button>
+      {open && (
+        <div className="absolute right-0 mt-2 w-64 bg-[#ffffff] border border-[#e8e8ee] rounded-2xl shadow-lg p-4 z-20 space-y-3">
+          <div>
+            <div className="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Format</div>
+            <div className="flex gap-1.5">
+              {FORMATS.map((f) => (
+                <button
+                  key={f.value}
+                  onClick={() => setFormat(f.value)}
+                  className={`text-xs px-2.5 py-1.5 rounded-lg font-medium transition-colors ${format === f.value ? 'bg-violet-500/10 text-violet-600 border border-violet-500/30' : 'bg-black/[0.04] text-zinc-500 hover:text-[#1b1b29] border border-transparent'}`}
+                >
+                  {f.label}
+                </button>
+              ))}
+            </div>
+          </div>
+          <div>
+            <div className="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Scope</div>
+            <div className="space-y-1">
+              {SCOPES(selectedCount).map((s) => (
+                <label key={s.value} className={`flex items-center gap-2 text-xs px-2 py-1.5 rounded-lg cursor-pointer ${s.disabled ? 'opacity-40 cursor-not-allowed' : 'hover:bg-black/[0.02]'}`}>
+                  <input
+                    type="radio"
+                    name="export-scope"
+                    checked={scope === s.value}
+                    disabled={s.disabled}
+                    onChange={() => setScope(s.value)}
+                  />
+                  <span className="text-zinc-700">{s.label}</span>
+                </label>
+              ))}
+            </div>
+          </div>
+          <button
+            onClick={handleExport}
+            className="w-full px-3 py-2 bg-violet-600 hover:bg-violet-500 text-white text-xs font-semibold rounded-xl transition-colors"
+          >
+            Download
+          </button>
+        </div>
+      )}
+    </div>
+  )
+}
