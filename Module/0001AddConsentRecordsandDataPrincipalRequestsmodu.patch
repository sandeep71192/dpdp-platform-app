diff --git a/src/app/api/dashboard/consent-records/[id]/route.ts b/src/app/api/dashboard/consent-records/[id]/route.ts
new file mode 100644
index 0000000..c4cfe8d
--- /dev/null
+++ b/src/app/api/dashboard/consent-records/[id]/route.ts
@@ -0,0 +1,85 @@
+import { NextRequest, NextResponse } from 'next/server'
+import { supabaseAdmin } from '@/lib/supabase'
+import { getSessionContext, canAccessClient } from '@/lib/auth'
+import { CONSENT_METHOD_LABELS, STATUS_META, consentDisplayId } from '@/lib/consent-records'
+import { humanizePurposeId } from '@/lib/consent-aggregation'
+import type { EventType } from '@/types/database'
+
+export const dynamic = 'force-dynamic'
+
+interface PurposeGroupConfig {
+  id: string
+  label: string
+}
+
+// GET /api/dashboard/consent-records/:id — full detail for the record drawer.
+export async function GET(request: NextRequest, { params }: { params: Promise<{ id: string }> }) {
+  const { id } = await params
+  const key = request.nextUrl.searchParams.get('key')
+  if (!key) return NextResponse.json({ error: 'key required' }, { status: 400 })
+
+  const { data: client } = await supabaseAdmin
+    .from('clients')
+    .select('id, name, domain')
+    .eq('client_key', key)
+    .single()
+
+  if (!client) return NextResponse.json({ error: 'Client not found' }, { status: 404 })
+
+  const ctx = await getSessionContext()
+  if (!canAccessClient(ctx, client.id)) return NextResponse.json({ error: 'Forbidden' }, { status: 403 })
+
+  const { data: record, error } = await supabaseAdmin
+    .from('consent_events')
+    .select('id, created_at, event_type, consented_to, language_used, device_type, country, page_url, session_id')
+    .eq('id', id)
+    .eq('client_id', client.id)
+    .single()
+
+  if (error || !record) return NextResponse.json({ error: 'Record not found' }, { status: 404 })
+
+  // Widget version isn't snapshotted per-event, so the currently published
+  // config version is shown as the closest available approximation.
+  const { data: config } = await supabaseAdmin
+    .from('widget_configs')
+    .select('version, purpose_groups')
+    .eq('client_id', client.id)
+    .eq('is_published', true)
+    .order('version', { ascending: false })
+    .limit(1)
+    .single()
+
+  const purposeGroups = Array.isArray(config?.purpose_groups)
+    ? (config!.purpose_groups as unknown as PurposeGroupConfig[])
+    : []
+  const labelById = new Map(purposeGroups.map((g) => [g.id, g.label]))
+
+  const consentedTo = (record.consented_to || {}) as Record<string, boolean>
+  const purposeSelection = Object.entries(consentedTo).map(([purposeId, accepted]) => ({
+    purpose: purposeId,
+    label: labelById.get(purposeId) || humanizePurposeId(purposeId),
+    accepted,
+  }))
+
+  const eventType = record.event_type as EventType
+  const status = STATUS_META[eventType as keyof typeof STATUS_META]
+
+  return NextResponse.json({
+    record: {
+      id: record.id,
+      consentId: consentDisplayId(record.id),
+      timestamp: record.created_at,
+      language: record.language_used,
+      status: record.event_type,
+      statusLabel: status?.label || record.event_type,
+      statusEmoji: status?.emoji || '',
+      widgetVersion: config?.version ?? null,
+      purposeSelection,
+      sourceWebsite: record.page_url,
+      consentMethod: CONSENT_METHOD_LABELS[eventType] || eventType,
+      deviceType: record.device_type,
+      country: record.country,
+      sessionId: record.session_id,
+    },
+  })
+}
diff --git a/src/app/api/dashboard/consent-records/export/route.ts b/src/app/api/dashboard/consent-records/export/route.ts
new file mode 100644
index 0000000..d12308d
--- /dev/null
+++ b/src/app/api/dashboard/consent-records/export/route.ts
@@ -0,0 +1,307 @@
+import { NextRequest, NextResponse } from 'next/server'
+import { supabaseAdmin } from '@/lib/supabase'
+import { getSessionContext, canAccessClient } from '@/lib/auth'
+import { resolveRange } from '@/lib/date-range'
+import { STATUS_META, consentDisplayId, CONSENT_METHOD_LABELS } from '@/lib/consent-records'
+import { fetchPurposeGroups, humanizePurposeId } from '@/lib/consent-aggregation'
+import { applyRecordFilters } from '../route'
+import * as XLSX from 'xlsx'
+import PDFDocument from 'pdfkit'
+import type { EventType } from '@/types/database'
+
+export const dynamic = 'force-dynamic'
+
+// Hard cap on rows pulled into a single export, fetched in batches below this
+// limit. Protects memory/runtime for clients with very large ledgers — the
+// CSV/Excel/PDF all note when the export was truncated.
+const MAX_EXPORT_ROWS = 50_000
+const BATCH_SIZE = 1000
+
+interface ExportRow {
+  id: string
+  created_at: string
+  event_type: EventType
+  consented_to: Record<string, boolean> | null
+  language_used: string | null
+  device_type: string | null
+  country: string | null
+  page_url: string | null
+  session_id: string | null
+}
+
+// GET /api/dashboard/consent-records/export
+// ?key=&format=csv|xlsx|pdf&scope=filtered|selected|all|range&...filters&ids=
+export async function GET(request: NextRequest) {
+  const params = request.nextUrl.searchParams
+  const key = params.get('key')
+  if (!key) return NextResponse.json({ error: 'key required' }, { status: 400 })
+
+  const { data: client } = await supabaseAdmin
+    .from('clients')
+    .select('id, name, domain')
+    .eq('client_key', key)
+    .single()
+
+  if (!client) return NextResponse.json({ error: 'Client not found' }, { status: 404 })
+
+  const ctx = await getSessionContext()
+  if (!canAccessClient(ctx, client.id)) return NextResponse.json({ error: 'Forbidden' }, { status: 403 })
+
+  const format = params.get('format') || 'csv'
+  const scope = params.get('scope') || 'filtered'
+
+  const range = params.get('range') || '30d'
+  const from = params.get('from')
+  const to = params.get('to')
+  const { since, until } = resolveRange(range, from, to)
+
+  const statuses = (params.get('status') || '').split(',').map((s) => s.trim()).filter(Boolean)
+  const purpose = params.get('purpose')
+  const language = params.get('language')
+  const search = params.get('search')
+  const ids = (params.get('ids') || '').split(',').map((s) => s.trim()).filter(Boolean)
+
+  const columns = 'id, created_at, event_type, consented_to, language_used, device_type, country, page_url, session_id'
+
+  let rows: ExportRow[] = []
+  let truncated = false
+  let filterCriteria: string
+
+  if (scope === 'selected') {
+    if (ids.length === 0) return NextResponse.json({ error: 'ids required for selected export' }, { status: 400 })
+    const { data, error } = await supabaseAdmin
+      .from('consent_events')
+      .select(columns)
+      .eq('client_id', client.id)
+      .in('id', ids)
+    if (error) return NextResponse.json({ error: error.message }, { status: 500 })
+    rows = (data || []) as unknown as ExportRow[]
+    filterCriteria = `Selected records (${ids.length})`
+  } else {
+    let filterOpts: Parameters<typeof applyRecordFilters>[1]
+    if (scope === 'all') {
+      filterOpts = { clientId: client.id, since: new Date(0), until: new Date() }
+      filterCriteria = 'All records'
+    } else if (scope === 'range') {
+      filterOpts = { clientId: client.id, since, until }
+      filterCriteria = `Date range: ${since.toISOString().slice(0, 10)} to ${until.toISOString().slice(0, 10)}`
+    } else {
+      filterOpts = { clientId: client.id, since, until, statuses, purpose, language, search }
+      const parts = [`Date range: ${since.toISOString().slice(0, 10)} to ${until.toISOString().slice(0, 10)}`]
+      if (statuses.length) parts.push(`Status: ${statuses.map((s) => STATUS_META[s as keyof typeof STATUS_META]?.label || s).join(', ')}`)
+      if (purpose) parts.push(`Purpose: ${humanizePurposeId(purpose)}`)
+      if (language) parts.push(`Language: ${language}`)
+      if (search) parts.push(`Search: "${search}"`)
+      filterCriteria = parts.join(' · ')
+    }
+
+    for (let offset = 0; offset < MAX_EXPORT_ROWS; offset += BATCH_SIZE) {
+      const { data, error } = await applyRecordFilters(
+        supabaseAdmin.from('consent_events').select(columns),
+        filterOpts,
+      )
+        .order('created_at', { ascending: false })
+        .range(offset, offset + BATCH_SIZE - 1)
+      if (error) return NextResponse.json({ error: error.message }, { status: 500 })
+      const batch = (data || []) as unknown as ExportRow[]
+      rows.push(...batch)
+      if (batch.length < BATCH_SIZE) break
+      if (rows.length >= MAX_EXPORT_ROWS) { truncated = true; break }
+    }
+  }
+
+  const purposeGroups = await fetchPurposeGroups(client.id)
+  const labelById = new Map(purposeGroups.map((g) => [g.id, g.label]))
+  const purposeLabel = (id: string) => labelById.get(id) || humanizePurposeId(id)
+
+  const filename = `dpdp-consent-records-${client.domain}-${new Date().toISOString().slice(0, 10)}`
+
+  if (format === 'xlsx') return buildXlsx(rows, client, filterCriteria, purposeLabel, filename)
+  if (format === 'pdf') return buildPdf(rows, client, filterCriteria, purposeLabel, filename, truncated)
+  return buildCsv(rows, client, filterCriteria, purposeLabel, filename, truncated)
+}
+
+function recordsToTable(rows: ExportRow[], purposeLabel: (id: string) => string) {
+  return rows.map((r) => {
+    const purposes = r.consented_to || {}
+    const accepted = Object.entries(purposes).filter(([, v]) => v).map(([k]) => purposeLabel(k))
+    const rejected = Object.entries(purposes).filter(([, v]) => !v).map(([k]) => purposeLabel(k))
+    return {
+      consentId: consentDisplayId(r.id),
+      timestamp: new Date(r.created_at).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Kolkata' }),
+      status: STATUS_META[r.event_type as keyof typeof STATUS_META]?.label || r.event_type,
+      language: r.language_used || '—',
+      purposesAccepted: accepted.join('; '),
+      purposesRejected: rejected.join('; '),
+      device: r.device_type || '—',
+      country: r.country || '—',
+      sourceWebsite: r.page_url || '—',
+      consentMethod: CONSENT_METHOD_LABELS[r.event_type as EventType] || r.event_type,
+      sessionId: r.session_id || '—',
+    }
+  })
+}
+
+function summaryStats(rows: ExportRow[]) {
+  const summary = { total: rows.length, accepted: 0, rejected: 0, customized: 0, withdrawn: 0 }
+  for (const r of rows) {
+    if (r.event_type === 'accepted_all') summary.accepted++
+    else if (r.event_type === 'rejected_all') summary.rejected++
+    else if (r.event_type === 'customised') summary.customized++
+    else if (r.event_type === 'withdrawn') summary.withdrawn++
+  }
+  return summary
+}
+
+function purposeAnalyticsTable(rows: ExportRow[], purposeLabel: (id: string) => string) {
+  const stats = new Map<string, { label: string; accepted: number; rejected: number }>()
+  for (const r of rows) {
+    for (const [purposeId, accepted] of Object.entries(r.consented_to || {})) {
+      const entry = stats.get(purposeId) || { label: purposeLabel(purposeId), accepted: 0, rejected: 0 }
+      if (accepted) entry.accepted++
+      else entry.rejected++
+      stats.set(purposeId, entry)
+    }
+  }
+  return Array.from(stats.entries()).map(([, s]) => ({
+    purpose: s.label,
+    accepted: s.accepted,
+    rejected: s.rejected,
+    total: s.accepted + s.rejected,
+    acceptRate: s.accepted + s.rejected ? Math.round((s.accepted / (s.accepted + s.rejected)) * 100) : 0,
+  }))
+}
+
+function buildCsv(rows: ExportRow[], client: { name: string }, filterCriteria: string, purposeLabel: (id: string) => string, filename: string, truncated: boolean) {
+  const header = 'consent_id,timestamp,status,language,purposes_accepted,purposes_rejected,device,country,source_website,consent_method,session_id\n'
+  const esc = (v: string) => `"${v.replace(/"/g, '""')}"`
+  const table = recordsToTable(rows, purposeLabel)
+  const body = table.map((r) => [
+    r.consentId, r.timestamp, r.status, r.language, r.purposesAccepted, r.purposesRejected,
+    r.device, r.country, r.sourceWebsite, r.consentMethod, r.sessionId,
+  ].map((v) => esc(String(v))).join(',')).join('\n')
+
+  const meta = [
+    `# Company: ${client.name}`,
+    `# Export date: ${new Date().toISOString()}`,
+    `# Filter criteria: ${filterCriteria}`,
+    truncated ? `# Note: export truncated at ${MAX_EXPORT_ROWS} records` : null,
+  ].filter(Boolean).join('\n') + '\n'
+
+  return new NextResponse(meta + header + body, {
+    headers: {
+      'Content-Type': 'text/csv',
+      'Content-Disposition': `attachment; filename="${filename}.csv"`,
+    },
+  })
+}
+
+function buildXlsx(rows: ExportRow[], client: { name: string }, filterCriteria: string, purposeLabel: (id: string) => string, filename: string) {
+  const wb = XLSX.utils.book_new()
+
+  const summary = summaryStats(rows)
+  const summarySheet = XLSX.utils.aoa_to_sheet([
+    ['Company', client.name],
+    ['Export Date', new Date().toISOString()],
+    ['Filter Criteria', filterCriteria],
+    [],
+    ['Metric', 'Count'],
+    ['Total Records', summary.total],
+    ['Accepted', summary.accepted],
+    ['Rejected', summary.rejected],
+    ['Customized', summary.customized],
+    ['Withdrawn', summary.withdrawn],
+  ])
+  XLSX.utils.book_append_sheet(wb, summarySheet, 'Summary')
+
+  const table = recordsToTable(rows, purposeLabel)
+  const recordsSheet = XLSX.utils.json_to_sheet(table, {
+    header: ['consentId', 'timestamp', 'status', 'language', 'purposesAccepted', 'purposesRejected', 'device', 'country', 'sourceWebsite', 'consentMethod', 'sessionId'],
+  })
+  XLSX.utils.sheet_add_aoa(recordsSheet, [['Consent ID', 'Timestamp (IST)', 'Status', 'Language', 'Purposes Accepted', 'Purposes Rejected', 'Device', 'Country', 'Source Website', 'Consent Method', 'Session ID']], { origin: 'A1' })
+  XLSX.utils.book_append_sheet(wb, recordsSheet, 'Consent Records')
+
+  const purposeTable = purposeAnalyticsTable(rows, purposeLabel)
+  const purposeSheet = XLSX.utils.json_to_sheet(purposeTable, { header: ['purpose', 'accepted', 'rejected', 'total', 'acceptRate'] })
+  XLSX.utils.sheet_add_aoa(purposeSheet, [['Purpose', 'Accepted', 'Rejected', 'Total', 'Accept Rate %']], { origin: 'A1' })
+  XLSX.utils.book_append_sheet(wb, purposeSheet, 'Purpose Analytics')
+
+  const buf = XLSX.write(wb, { type: 'buffer', bookType: 'xlsx' })
+  return new NextResponse(buf, {
+    headers: {
+      'Content-Type': 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
+      'Content-Disposition': `attachment; filename="${filename}.xlsx"`,
+    },
+  })
+}
+
+// PDF is capped to a representative page of rows — full data is available
+// via the CSV/Excel exports — but always includes filter criteria + summary
+// statistics for audit purposes.
+const PDF_ROW_LIMIT = 500
+
+function buildPdf(rows: ExportRow[], client: { name: string }, filterCriteria: string, purposeLabel: (id: string) => string, filename: string, truncated: boolean): Promise<NextResponse> {
+  return new Promise((resolve) => {
+    const doc = new PDFDocument({ margin: 40, size: 'A4', layout: 'landscape' })
+    const chunks: Buffer[] = []
+    doc.on('data', (chunk) => chunks.push(chunk))
+    doc.on('end', () => {
+      const buf = Buffer.concat(chunks)
+      resolve(new NextResponse(buf, {
+        headers: {
+          'Content-Type': 'application/pdf',
+          'Content-Disposition': `attachment; filename="${filename}.pdf"`,
+        },
+      }))
+    })
+
+    doc.fontSize(16).text(`${client.name} — Consent Records Export`, { align: 'left' })
+    doc.fontSize(9).fillColor('#666666')
+    doc.text(`Export Date: ${new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' })} IST`)
+    doc.text(`Filter Criteria: ${filterCriteria}`)
+    doc.fillColor('#000000')
+    doc.moveDown(0.5)
+
+    const summary = summaryStats(rows)
+    doc.fontSize(11).text('Summary Statistics', { underline: true })
+    doc.fontSize(9).text(`Total: ${summary.total}   Accepted: ${summary.accepted}   Rejected: ${summary.rejected}   Customized: ${summary.customized}   Withdrawn: ${summary.withdrawn}`)
+    doc.moveDown(0.5)
+
+    doc.fontSize(11).text('Consent Records', { underline: true })
+    doc.moveDown(0.25)
+
+    const table = recordsToTable(rows.slice(0, PDF_ROW_LIMIT), purposeLabel)
+    const colWidths = [70, 110, 70, 60, 140, 140, 60, 60, 100]
+    const headers = ['Consent ID', 'Timestamp (IST)', 'Status', 'Language', 'Purposes Accepted', 'Purposes Rejected', 'Device', 'Country', 'Consent Method']
+    const startX = doc.x
+    let y = doc.y
+
+    function drawRow(values: string[], bold: boolean) {
+      doc.fontSize(7).font(bold ? 'Helvetica-Bold' : 'Helvetica')
+      let x = startX
+      values.forEach((v, i) => {
+        doc.text(v, x, y, { width: colWidths[i], ellipsis: true })
+        x += colWidths[i]
+      })
+      y += 14
+      if (y > doc.page.height - 40) {
+        doc.addPage()
+        y = doc.y
+      }
+    }
+
+    drawRow(headers, true)
+    for (const r of table) {
+      drawRow([r.consentId, r.timestamp, r.status, r.language, r.purposesAccepted, r.purposesRejected, r.device, r.country, r.consentMethod], false)
+    }
+
+    if (truncated || rows.length > PDF_ROW_LIMIT) {
+      doc.moveDown(1)
+      doc.fontSize(8).fillColor('#888888').text(
+        `Showing ${Math.min(rows.length, PDF_ROW_LIMIT)} of ${rows.length} records. Export as CSV or Excel for the complete dataset.`
+      )
+    }
+
+    doc.end()
+  })
+}
diff --git a/src/app/api/dashboard/consent-records/route.ts b/src/app/api/dashboard/consent-records/route.ts
new file mode 100644
index 0000000..ddfc119
--- /dev/null
+++ b/src/app/api/dashboard/consent-records/route.ts
@@ -0,0 +1,159 @@
+import { NextRequest, NextResponse } from 'next/server'
+import { supabaseAdmin } from '@/lib/supabase'
+import { getSessionContext, canAccessClient } from '@/lib/auth'
+import { resolveRange } from '@/lib/date-range'
+import { fetchPurposeGroups, fetchEnabledLanguages, humanizePurposeId } from '@/lib/consent-aggregation'
+import { LEDGER_EVENT_TYPES, STATUS_META, consentDisplayId, resolveSearch, isSortableColumn, isLedgerEventType, PAGE_SIZES } from '@/lib/consent-records'
+
+export const dynamic = 'force-dynamic'
+
+// Applies the shared date/status/purpose/language/search filters to a
+// consent_events query builder. Reused for the paginated list, the summary
+// counts and (via the export route) bulk exports — keeping all of those
+// consistent with whatever the user has filtered on screen.
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+export function applyRecordFilters<T extends Record<string, any>>(query: T, opts: {
+  clientId: string
+  since: Date
+  until: Date
+  statuses?: string[]
+  purpose?: string | null
+  language?: string | null
+  search?: string | null
+}): T {
+  let q = query
+    .eq('client_id', opts.clientId)
+    .gte('created_at', opts.since.toISOString())
+    .lte('created_at', opts.until.toISOString())
+
+  const statuses = (opts.statuses && opts.statuses.length > 0)
+    ? opts.statuses.filter(isLedgerEventType)
+    : [...LEDGER_EVENT_TYPES]
+  q = q.in('event_type', statuses.length > 0 ? statuses : [...LEDGER_EVENT_TYPES])
+
+  if (opts.purpose) {
+    q = q.contains('consented_to', { [opts.purpose]: true })
+  }
+  if (opts.language) {
+    q = q.eq('language_used', opts.language)
+  }
+  if (opts.search) {
+    const resolved = resolveSearch(opts.search)
+    if (resolved) {
+      q = resolved.op === 'eq' ? q.eq(resolved.column, resolved.value) : q.ilike(resolved.column, resolved.value)
+    }
+  }
+  return q
+}
+
+// GET /api/dashboard/consent-records — paginated, filterable, searchable
+// audit ledger backed entirely by consent_events. Designed to scale from
+// dozens to 1M+ rows: list query uses .range() pagination and summary
+// metrics use count-only ("head") aggregation queries.
+export async function GET(request: NextRequest) {
+  const params = request.nextUrl.searchParams
+  const key = params.get('key')
+  if (!key) return NextResponse.json({ error: 'key required' }, { status: 400 })
+
+  const { data: client } = await supabaseAdmin
+    .from('clients')
+    .select('id, name, domain')
+    .eq('client_key', key)
+    .single()
+
+  if (!client) return NextResponse.json({ error: 'Client not found' }, { status: 404 })
+
+  const ctx = await getSessionContext()
+  if (!canAccessClient(ctx, client.id)) return NextResponse.json({ error: 'Forbidden' }, { status: 403 })
+
+  const range = params.get('range') || '30d'
+  const from = params.get('from')
+  const to = params.get('to')
+  const { since, until } = resolveRange(range, from, to)
+
+  const statuses = (params.get('status') || '').split(',').map((s) => s.trim()).filter(Boolean)
+  const purpose = params.get('purpose')
+  const language = params.get('language')
+  const search = params.get('search')
+
+  const sortByParam = params.get('sortBy') || 'created_at'
+  const sortBy = isSortableColumn(sortByParam) ? sortByParam : 'created_at'
+  const sortDir = params.get('sortDir') === 'asc' ? 'asc' : 'desc'
+
+  const pageSizeParam = parseInt(params.get('pageSize') || '25', 10)
+  const pageSize = (PAGE_SIZES as readonly number[]).includes(pageSizeParam) ? pageSizeParam : 25
+  const page = Math.max(1, parseInt(params.get('page') || '1', 10))
+
+  const filterOpts = { clientId: client.id, since, until, statuses, purpose, language, search }
+
+  const [listRes, ...summaryRes] = await Promise.all([
+    applyRecordFilters(
+      supabaseAdmin.from('consent_events').select('id, created_at, event_type, language_used, consented_to, session_id', { count: 'exact' }),
+      filterOpts,
+    )
+      .order(sortBy, { ascending: sortDir === 'asc' })
+      .range((page - 1) * pageSize, page * pageSize - 1),
+    ...LEDGER_EVENT_TYPES.map((eventType) =>
+      applyRecordFilters(
+        supabaseAdmin.from('consent_events').select('*', { count: 'exact', head: true }),
+        { clientId: client.id, since, until, statuses: [eventType], purpose, language, search },
+      )
+    ),
+  ])
+
+  if (listRes.error) return NextResponse.json({ error: listRes.error.message }, { status: 500 })
+
+  const summary = {
+    total: 0,
+    accepted: 0,
+    rejected: 0,
+    customized: 0,
+    withdrawn: 0,
+  }
+  const summaryKeys: Record<typeof LEDGER_EVENT_TYPES[number], keyof typeof summary> = {
+    accepted_all: 'accepted',
+    rejected_all: 'rejected',
+    customised: 'customized',
+    withdrawn: 'withdrawn',
+  }
+  LEDGER_EVENT_TYPES.forEach((eventType, i) => {
+    const count = summaryRes[i].count || 0
+    summary[summaryKeys[eventType]] = count
+    summary.total += count
+  })
+
+  const records = (listRes.data || []).map((r) => {
+    const purposes = (r.consented_to || {}) as Record<string, boolean>
+    return {
+      id: r.id,
+      consentId: consentDisplayId(r.id),
+      timestamp: r.created_at,
+      language: r.language_used,
+      status: r.event_type,
+      statusLabel: STATUS_META[r.event_type as keyof typeof STATUS_META]?.label || r.event_type,
+      statusEmoji: STATUS_META[r.event_type as keyof typeof STATUS_META]?.emoji || '',
+      purposesAccepted: Object.entries(purposes).filter(([, v]) => v).map(([k]) => k),
+      purposesRejected: Object.entries(purposes).filter(([, v]) => !v).map(([k]) => k),
+    }
+  })
+
+  const [purposeGroups, languages] = await Promise.all([
+    fetchPurposeGroups(client.id),
+    fetchEnabledLanguages(client.id),
+  ])
+
+  return NextResponse.json({
+    client,
+    records,
+    count: listRes.count || 0,
+    page,
+    pageSize,
+    summary,
+    filters: {
+      statuses: LEDGER_EVENT_TYPES.map((eventType) => ({ value: eventType, ...STATUS_META[eventType] })),
+      purposes: purposeGroups.map((g) => ({ value: g.id, label: g.label || humanizePurposeId(g.id) })),
+      languages,
+    },
+    range,
+  })
+}
diff --git a/src/app/api/dashboard/dpr-requests/[id]/route.ts b/src/app/api/dashboard/dpr-requests/[id]/route.ts
new file mode 100644
index 0000000..0cf0018
--- /dev/null
+++ b/src/app/api/dashboard/dpr-requests/[id]/route.ts
@@ -0,0 +1,203 @@
+import { NextRequest, NextResponse } from 'next/server'
+import { supabaseAdmin } from '@/lib/supabase'
+import { getSessionContext, canAccessClient } from '@/lib/auth'
+import {
+  STATUS_META, dprDisplayId, requestTypeMeta, canTransition, isValidStatus, isValidPriority,
+} from '@/lib/dpr-requests'
+import type { DPRRequest, DPRStatus } from '@/types/database'
+
+export const dynamic = 'force-dynamic'
+
+async function loadClient(key: string | null) {
+  if (!key) return null
+  const { data } = await supabaseAdmin.from('clients').select('id, name, domain').eq('client_key', key).single()
+  return data
+}
+
+// GET /api/dashboard/dpr-requests/:id — full detail: request, timeline,
+// notes, assignment history.
+export async function GET(request: NextRequest, { params }: { params: Promise<{ id: string }> }) {
+  const { id } = await params
+  const client = await loadClient(request.nextUrl.searchParams.get('key'))
+  if (!client) return NextResponse.json({ error: 'Client not found' }, { status: 404 })
+
+  const ctx = await getSessionContext()
+  if (!canAccessClient(ctx, client.id)) return NextResponse.json({ error: 'Forbidden' }, { status: 403 })
+
+  const [{ data: record, error }, { data: events }, { data: notes }, { data: assignments }] = await Promise.all([
+    supabaseAdmin.from('dpr_requests').select('*').eq('id', id).eq('client_id', client.id).single(),
+    supabaseAdmin.from('dpr_request_events').select('*').eq('request_id', id).order('created_at', { ascending: true }),
+    supabaseAdmin.from('dpr_request_notes').select('*').eq('request_id', id).order('created_at', { ascending: true }),
+    supabaseAdmin.from('dpr_request_assignments').select('*').eq('request_id', id).order('created_at', { ascending: true }),
+  ])
+
+  if (error || !record) return NextResponse.json({ error: 'Request not found' }, { status: 404 })
+
+  const r = record as DPRRequest
+  const meta = requestTypeMeta(r.request_type)
+  const now = new Date()
+
+  return NextResponse.json({
+    request: {
+      id: r.id,
+      requestId: dprDisplayId(r.id),
+      requestType: r.request_type,
+      requestTypeLabel: meta.label,
+      requestTypeDescription: meta.description,
+      highRisk: !!meta.highRisk,
+      requesterName: r.requester_name,
+      requesterEmail: r.requester_email,
+      userIdentifier: r.user_identifier,
+      description: r.description,
+      status: r.status,
+      statusLabel: STATUS_META[r.status].label,
+      statusEmoji: STATUS_META[r.status].emoji,
+      priority: r.priority,
+      assignedToName: r.assigned_to_name,
+      assignedToUserId: r.assigned_to_user_id,
+      assignedAt: r.assigned_at,
+      startedAt: r.started_at,
+      completedAt: r.completed_at,
+      dueAt: r.due_at,
+      overdue: r.status !== 'completed' && !!r.due_at && new Date(r.due_at) < now,
+      resolutionNotes: r.resolution_notes,
+      proofOfCompletion: r.proof_of_completion,
+      attachments: r.attachments,
+      createdAt: r.created_at,
+      updatedAt: r.updated_at,
+    },
+    timeline: events || [],
+    notes: notes || [],
+    assignments: assignments || [],
+  })
+}
+
+interface PatchBody {
+  action: 'assign' | 'status' | 'note' | 'priority'
+  // assign
+  assignedToName?: string
+  assignedToUserId?: string | null
+  // status
+  status?: DPRStatus
+  resolutionNotes?: string
+  proofOfCompletion?: string
+  // note
+  note?: string
+  // priority
+  priority?: string
+}
+
+// PATCH /api/dashboard/dpr-requests/:id — single-action mutation (assign,
+// status transition, add note, change priority). Every action appends an
+// immutable event to dpr_request_events.
+export async function PATCH(request: NextRequest, { params }: { params: Promise<{ id: string }> }) {
+  const { id } = await params
+  const client = await loadClient(request.nextUrl.searchParams.get('key'))
+  if (!client) return NextResponse.json({ error: 'Client not found' }, { status: 404 })
+
+  const ctx = await getSessionContext()
+  if (!canAccessClient(ctx, client.id)) return NextResponse.json({ error: 'Forbidden' }, { status: 403 })
+
+  const { data: existing, error: fetchErr } = await supabaseAdmin
+    .from('dpr_requests').select('*').eq('id', id).eq('client_id', client.id).single()
+  if (fetchErr || !existing) return NextResponse.json({ error: 'Request not found' }, { status: 404 })
+
+  const current = existing as DPRRequest
+  const body = (await request.json()) as PatchBody
+  const actorEmail = ctx?.email || null
+  const actorName = ctx?.email || 'Staff'
+  const now = new Date().toISOString()
+
+  if (body.action === 'assign') {
+    if (!body.assignedToName) return NextResponse.json({ error: 'assignedToName required' }, { status: 400 })
+
+    const nextStatus: DPRStatus = current.status === 'open' ? 'assigned' : current.status
+    const { error } = await supabaseAdmin.from('dpr_requests').update({
+      assigned_to_name: body.assignedToName,
+      assigned_to_user_id: body.assignedToUserId || null,
+      assigned_at: now,
+      status: nextStatus,
+    }).eq('id', id)
+    if (error) return NextResponse.json({ error: error.message }, { status: 500 })
+
+    await supabaseAdmin.from('dpr_request_assignments').insert({
+      request_id: id,
+      assigned_to_user_id: body.assignedToUserId || null,
+      assigned_to_name: body.assignedToName,
+      assigned_by_email: actorEmail,
+    })
+
+    const eventType = current.assigned_to_name ? 'reassigned' : 'assigned'
+    await supabaseAdmin.from('dpr_request_events').insert({
+      request_id: id,
+      event_type: eventType,
+      actor_name: actorName,
+      actor_email: actorEmail,
+      from_status: current.status,
+      to_status: nextStatus,
+      message: `Assigned to ${body.assignedToName}`,
+    })
+  } else if (body.action === 'status') {
+    if (!body.status || !isValidStatus(body.status)) return NextResponse.json({ error: 'Invalid status' }, { status: 400 })
+    if (!canTransition(current.status, body.status)) {
+      return NextResponse.json({ error: `Cannot transition from ${current.status} to ${body.status}` }, { status: 400 })
+    }
+
+    // eslint-disable-next-line @typescript-eslint/no-explicit-any
+    const updates: Record<string, any> = { status: body.status }
+    if (body.status === 'in_progress' && !current.started_at) updates.started_at = now
+    if (body.status === 'completed') {
+      updates.completed_at = now
+      if (!current.started_at) updates.started_at = now
+      if (body.resolutionNotes !== undefined) updates.resolution_notes = body.resolutionNotes
+      if (body.proofOfCompletion !== undefined) updates.proof_of_completion = body.proofOfCompletion
+    }
+
+    const { error } = await supabaseAdmin.from('dpr_requests').update(updates).eq('id', id)
+    if (error) return NextResponse.json({ error: error.message }, { status: 500 })
+
+    await supabaseAdmin.from('dpr_request_events').insert({
+      request_id: id,
+      event_type: body.status === 'completed' ? 'completed' : 'status_changed',
+      actor_name: actorName,
+      actor_email: actorEmail,
+      from_status: current.status,
+      to_status: body.status,
+      message: body.status === 'completed' ? 'Request marked completed' : `Status changed to ${STATUS_META[body.status].label}`,
+    })
+  } else if (body.action === 'note') {
+    if (!body.note || !body.note.trim()) return NextResponse.json({ error: 'note required' }, { status: 400 })
+
+    await supabaseAdmin.from('dpr_request_notes').insert({
+      request_id: id,
+      author_name: actorName,
+      author_email: actorEmail,
+      note: body.note.trim(),
+    })
+
+    await supabaseAdmin.from('dpr_request_events').insert({
+      request_id: id,
+      event_type: 'note_added',
+      actor_name: actorName,
+      actor_email: actorEmail,
+      message: body.note.trim(),
+    })
+  } else if (body.action === 'priority') {
+    if (!body.priority || !isValidPriority(body.priority)) return NextResponse.json({ error: 'Invalid priority' }, { status: 400 })
+
+    const { error } = await supabaseAdmin.from('dpr_requests').update({ priority: body.priority }).eq('id', id)
+    if (error) return NextResponse.json({ error: error.message }, { status: 500 })
+
+    await supabaseAdmin.from('dpr_request_events').insert({
+      request_id: id,
+      event_type: 'priority_changed',
+      actor_name: actorName,
+      actor_email: actorEmail,
+      message: `Priority changed from ${current.priority} to ${body.priority}`,
+    })
+  } else {
+    return NextResponse.json({ error: 'Invalid action' }, { status: 400 })
+  }
+
+  return NextResponse.json({ ok: true })
+}
diff --git a/src/app/api/dashboard/dpr-requests/export/route.ts b/src/app/api/dashboard/dpr-requests/export/route.ts
new file mode 100644
index 0000000..9b35b51
--- /dev/null
+++ b/src/app/api/dashboard/dpr-requests/export/route.ts
@@ -0,0 +1,234 @@
+import { NextRequest, NextResponse } from 'next/server'
+import { supabaseAdmin } from '@/lib/supabase'
+import { getSessionContext, canAccessClient } from '@/lib/auth'
+import { resolveRange } from '@/lib/date-range'
+import { dprDisplayId, STATUS_META, requestTypeMeta, isValidRequestType, isValidStatus, isValidPriority } from '@/lib/dpr-requests'
+import { applyFilters } from '../route'
+import * as XLSX from 'xlsx'
+import PDFDocument from 'pdfkit'
+import type { DPRRequest } from '@/types/database'
+
+export const dynamic = 'force-dynamic'
+
+const MAX_EXPORT_ROWS = 20_000
+
+// GET /api/dashboard/dpr-requests/export?key=&format=csv|xlsx|pdf&scope=filtered|selected|all&ids=&...filters
+export async function GET(request: NextRequest) {
+  const params = request.nextUrl.searchParams
+  const key = params.get('key')
+  if (!key) return NextResponse.json({ error: 'key required' }, { status: 400 })
+
+  const { data: client } = await supabaseAdmin.from('clients').select('id, name').eq('client_key', key).single()
+  if (!client) return NextResponse.json({ error: 'Client not found' }, { status: 404 })
+
+  const ctx = await getSessionContext()
+  if (!canAccessClient(ctx, client.id)) return NextResponse.json({ error: 'Forbidden' }, { status: 403 })
+
+  const format = params.get('format') || 'csv'
+  const scope = params.get('scope') || 'filtered'
+
+  const range = params.get('range') || '90d'
+  const from = params.get('from')
+  const to = params.get('to')
+  const { since, until } = resolveRange(range, from, to)
+
+  const statuses = (params.get('status') || '').split(',').map((s) => s.trim()).filter(isValidStatus)
+  const types = (params.get('type') || '').split(',').map((s) => s.trim()).filter(isValidRequestType)
+  const priorities = (params.get('priority') || '').split(',').map((s) => s.trim()).filter(isValidPriority)
+  const assignedTo = params.get('assignedTo')
+  const ids = (params.get('ids') || '').split(',').map((s) => s.trim()).filter(Boolean)
+
+  let rows: DPRRequest[]
+  let filterCriteria: string
+
+  if (scope === 'selected') {
+    if (ids.length === 0) return NextResponse.json({ error: 'ids required for selected export' }, { status: 400 })
+    const { data, error } = await supabaseAdmin.from('dpr_requests').select('*').eq('client_id', client.id).in('id', ids)
+    if (error) return NextResponse.json({ error: error.message }, { status: 500 })
+    rows = (data || []) as DPRRequest[]
+    filterCriteria = `Selected requests (${ids.length})`
+  } else {
+    const filterOpts = scope === 'all'
+      ? { clientId: client.id, since: new Date(0), until: new Date() }
+      : { clientId: client.id, since, until, statuses, types, priorities, assignedTo }
+
+    const { data, error } = await applyFilters(
+      supabaseAdmin.from('dpr_requests').select('*'),
+      filterOpts,
+    ).order('created_at', { ascending: false }).limit(MAX_EXPORT_ROWS)
+
+    if (error) return NextResponse.json({ error: error.message }, { status: 500 })
+    rows = (data || []) as DPRRequest[]
+
+    if (scope === 'all') {
+      filterCriteria = 'All requests'
+    } else {
+      const parts = [`Date range: ${since.toISOString().slice(0, 10)} to ${until.toISOString().slice(0, 10)}`]
+      if (statuses.length) parts.push(`Status: ${statuses.map((s) => STATUS_META[s as keyof typeof STATUS_META]?.label || s).join(', ')}`)
+      if (types.length) parts.push(`Type: ${types.map((t) => requestTypeMeta(t).label).join(', ')}`)
+      if (priorities.length) parts.push(`Priority: ${priorities.join(', ')}`)
+      if (assignedTo) parts.push(`Assigned to: ${assignedTo}`)
+      filterCriteria = parts.join(' · ')
+    }
+  }
+
+  const filename = `dpdp-data-principal-requests-${new Date().toISOString().slice(0, 10)}`
+
+  if (format === 'xlsx') return buildXlsx(rows, client, filterCriteria, filename)
+  if (format === 'pdf') return buildPdf(rows, client, filterCriteria, filename)
+  return buildCsv(rows, filterCriteria, filename)
+}
+
+function recordsToTable(rows: DPRRequest[]) {
+  return rows.map((r) => ({
+    requestId: dprDisplayId(r.id),
+    requestType: requestTypeMeta(r.request_type).label,
+    requesterName: r.requester_name || '—',
+    requesterEmail: r.requester_email,
+    userIdentifier: r.user_identifier || '—',
+    submissionDate: new Date(r.created_at).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Kolkata' }),
+    status: STATUS_META[r.status].label,
+    priority: r.priority,
+    assignedTo: r.assigned_to_name || '—',
+    dueDate: r.due_at ? new Date(r.due_at).toLocaleDateString('en-IN', { timeZone: 'Asia/Kolkata' }) : '—',
+    completedDate: r.completed_at ? new Date(r.completed_at).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Kolkata' }) : '—',
+  }))
+}
+
+function summaryStats(rows: DPRRequest[]) {
+  const summary = { total: rows.length, open: 0, assigned: 0, inProgress: 0, completed: 0, overdue: 0 }
+  const now = new Date()
+  for (const r of rows) {
+    if (r.status === 'open') summary.open++
+    else if (r.status === 'assigned') summary.assigned++
+    else if (r.status === 'in_progress') summary.inProgress++
+    else if (r.status === 'completed') summary.completed++
+    if (r.status !== 'completed' && r.due_at && new Date(r.due_at) < now) summary.overdue++
+  }
+  return summary
+}
+
+function buildCsv(rows: DPRRequest[], filterCriteria: string, filename: string) {
+  const header = 'request_id,request_type,requester_name,requester_email,user_identifier,submission_date,status,priority,assigned_to,due_date,completed_date\n'
+  const esc = (v: string) => `"${v.replace(/"/g, '""')}"`
+  const table = recordsToTable(rows)
+  const body = table.map((r) => [
+    r.requestId, r.requestType, r.requesterName, r.requesterEmail, r.userIdentifier,
+    r.submissionDate, r.status, r.priority, r.assignedTo, r.dueDate, r.completedDate,
+  ].map((v) => esc(String(v))).join(',')).join('\n')
+
+  const meta = [
+    `# Export date: ${new Date().toISOString()}`,
+    `# Filter criteria: ${filterCriteria}`,
+  ].join('\n') + '\n'
+
+  return new NextResponse(meta + header + body, {
+    headers: {
+      'Content-Type': 'text/csv',
+      'Content-Disposition': `attachment; filename="${filename}.csv"`,
+    },
+  })
+}
+
+function buildXlsx(rows: DPRRequest[], client: { name: string }, filterCriteria: string, filename: string) {
+  const wb = XLSX.utils.book_new()
+  const summary = summaryStats(rows)
+
+  const summarySheet = XLSX.utils.aoa_to_sheet([
+    ['Company', client.name],
+    ['Export Date', new Date().toISOString()],
+    ['Filter Criteria', filterCriteria],
+    [],
+    ['Metric', 'Count'],
+    ['Total Requests', summary.total],
+    ['Open', summary.open],
+    ['Assigned', summary.assigned],
+    ['In Progress', summary.inProgress],
+    ['Completed', summary.completed],
+    ['Overdue', summary.overdue],
+  ])
+  XLSX.utils.book_append_sheet(wb, summarySheet, 'Summary')
+
+  const table = recordsToTable(rows)
+  const recordsSheet = XLSX.utils.json_to_sheet(table, {
+    header: ['requestId', 'requestType', 'requesterName', 'requesterEmail', 'userIdentifier', 'submissionDate', 'status', 'priority', 'assignedTo', 'dueDate', 'completedDate'],
+  })
+  XLSX.utils.sheet_add_aoa(recordsSheet, [['Request ID', 'Request Type', 'Requester Name', 'Requester Email', 'User Identifier', 'Submission Date', 'Status', 'Priority', 'Assigned To', 'Due Date', 'Completed Date']], { origin: 'A1' })
+  XLSX.utils.book_append_sheet(wb, recordsSheet, 'Requests')
+
+  const buf = XLSX.write(wb, { type: 'buffer', bookType: 'xlsx' })
+  return new NextResponse(buf, {
+    headers: {
+      'Content-Type': 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
+      'Content-Disposition': `attachment; filename="${filename}.xlsx"`,
+    },
+  })
+}
+
+const PDF_ROW_LIMIT = 500
+
+function buildPdf(rows: DPRRequest[], client: { name: string }, filterCriteria: string, filename: string): Promise<NextResponse> {
+  return new Promise((resolve) => {
+    const doc = new PDFDocument({ margin: 40, size: 'A4', layout: 'landscape' })
+    const chunks: Buffer[] = []
+    doc.on('data', (chunk) => chunks.push(chunk))
+    doc.on('end', () => {
+      const buf = Buffer.concat(chunks)
+      resolve(new NextResponse(buf, {
+        headers: {
+          'Content-Type': 'application/pdf',
+          'Content-Disposition': `attachment; filename="${filename}.pdf"`,
+        },
+      }))
+    })
+
+    doc.fontSize(16).text(`${client.name} — Data Principal Requests Export`)
+    doc.fontSize(9).fillColor('#666666')
+    doc.text(`Export Date: ${new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' })} IST`)
+    doc.text(`Filter Criteria: ${filterCriteria}`)
+    doc.fillColor('#000000')
+    doc.moveDown(0.5)
+
+    const summary = summaryStats(rows)
+    doc.fontSize(11).text('Summary Statistics', { underline: true })
+    doc.fontSize(9).text(`Total: ${summary.total}   Open: ${summary.open}   Assigned: ${summary.assigned}   In Progress: ${summary.inProgress}   Completed: ${summary.completed}   Overdue: ${summary.overdue}`)
+    doc.moveDown(0.5)
+
+    doc.fontSize(11).text('Requests', { underline: true })
+    doc.moveDown(0.25)
+
+    const table = recordsToTable(rows.slice(0, PDF_ROW_LIMIT))
+    const colWidths = [70, 100, 110, 150, 100, 70, 70, 70, 100]
+    const headers = ['Request ID', 'Type', 'Requester', 'Email', 'Submitted', 'Status', 'Priority', 'Due', 'Assigned To']
+    const startX = doc.x
+    let y = doc.y
+
+    function drawRow(values: string[], bold: boolean) {
+      doc.fontSize(7).font(bold ? 'Helvetica-Bold' : 'Helvetica')
+      let x = startX
+      values.forEach((v, i) => {
+        doc.text(v, x, y, { width: colWidths[i], ellipsis: true })
+        x += colWidths[i]
+      })
+      y += 14
+      if (y > doc.page.height - 40) {
+        doc.addPage()
+        y = doc.y
+      }
+    }
+
+    drawRow(headers, true)
+    for (const r of table) {
+      drawRow([r.requestId, r.requestType, r.requesterName, r.requesterEmail, r.submissionDate, r.status, r.priority, r.dueDate, r.assignedTo], false)
+    }
+
+    if (rows.length > PDF_ROW_LIMIT) {
+      doc.moveDown(1)
+      doc.fontSize(8).fillColor('#888888').text(
+        `Showing ${PDF_ROW_LIMIT} of ${rows.length} requests. Export as CSV or Excel for the complete dataset.`
+      )
+    }
+
+    doc.end()
+  })
+}
diff --git a/src/app/api/dashboard/dpr-requests/route.ts b/src/app/api/dashboard/dpr-requests/route.ts
new file mode 100644
index 0000000..979cbc7
--- /dev/null
+++ b/src/app/api/dashboard/dpr-requests/route.ts
@@ -0,0 +1,261 @@
+import { NextRequest, NextResponse } from 'next/server'
+import { supabaseAdmin } from '@/lib/supabase'
+import { getSessionContext, canAccessClient } from '@/lib/auth'
+import { resolveRange } from '@/lib/date-range'
+import {
+  STATUSES, PRIORITIES, REQUEST_TYPES, STATUS_META,
+  dprDisplayId, isSortableColumn, isValidRequestType, isValidStatus, isValidPriority,
+  requestTypeMeta, computeDueDate, PAGE_SIZES,
+} from '@/lib/dpr-requests'
+import type { DPRRequest } from '@/types/database'
+
+export const dynamic = 'force-dynamic'
+
+const DPR_ID_RE = /^DPR-(\d{6})$/i
+const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i
+
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+export function applyFilters<T extends Record<string, any>>(query: T, opts: {
+  clientId: string
+  since: Date
+  until: Date
+  statuses?: string[]
+  types?: string[]
+  priorities?: string[]
+  assignedTo?: string | null
+  matchIds?: string[] | null
+}): T {
+  let q = query
+    .eq('client_id', opts.clientId)
+    .gte('created_at', opts.since.toISOString())
+    .lte('created_at', opts.until.toISOString())
+
+  if (opts.statuses && opts.statuses.length > 0) q = q.in('status', opts.statuses)
+  if (opts.types && opts.types.length > 0) q = q.in('request_type', opts.types)
+  if (opts.priorities && opts.priorities.length > 0) q = q.in('priority', opts.priorities)
+  if (opts.assignedTo) q = q.eq('assigned_to_name', opts.assignedTo)
+  if (opts.matchIds) q = q.in('id', opts.matchIds)
+  return q
+}
+
+// GET /api/dashboard/dpr-requests — paginated, filterable, searchable list of
+// Data Principal Requests + summary metrics + SLA stats.
+export async function GET(request: NextRequest) {
+  const params = request.nextUrl.searchParams
+  const key = params.get('key')
+  if (!key) return NextResponse.json({ error: 'key required' }, { status: 400 })
+
+  const { data: client } = await supabaseAdmin
+    .from('clients')
+    .select('id, name, domain')
+    .eq('client_key', key)
+    .single()
+
+  if (!client) return NextResponse.json({ error: 'Client not found' }, { status: 404 })
+
+  const ctx = await getSessionContext()
+  if (!canAccessClient(ctx, client.id)) return NextResponse.json({ error: 'Forbidden' }, { status: 403 })
+
+  const range = params.get('range') || '90d'
+  const from = params.get('from')
+  const to = params.get('to')
+  const { since, until } = resolveRange(range, from, to)
+
+  const statuses = (params.get('status') || '').split(',').map((s) => s.trim()).filter(isValidStatus)
+  const types = (params.get('type') || '').split(',').map((s) => s.trim()).filter(isValidRequestType)
+  const priorities = (params.get('priority') || '').split(',').map((s) => s.trim()).filter(isValidPriority)
+  const assignedTo = params.get('assignedTo')
+  const search = (params.get('search') || '').trim()
+
+  const sortByParam = params.get('sortBy') || 'created_at'
+  const sortBy = isSortableColumn(sortByParam) ? sortByParam : 'created_at'
+  const sortDir = params.get('sortDir') === 'asc' ? 'asc' : 'desc'
+
+  const pageSizeParam = parseInt(params.get('pageSize') || '25', 10)
+  const pageSize = (PAGE_SIZES as readonly number[]).includes(pageSizeParam) ? pageSizeParam : 25
+  const page = Math.max(1, parseInt(params.get('page') || '1', 10))
+
+  // Resolve search term to either an `id`/email/identifier match. Request
+  // volume per client is small (thousands, not millions), so a DPR-XXXXXX
+  // search resolves via a lightweight id scan rather than a reverse hash.
+  let matchIds: string[] | null = null
+  let emailOrIdentifierFilter: { column: string; value: string } | null = null
+  if (search) {
+    const dprMatch = search.match(DPR_ID_RE)
+    if (dprMatch) {
+      const { data: idRows } = await supabaseAdmin.from('dpr_requests').select('id').eq('client_id', client.id)
+      matchIds = (idRows || []).map((r) => r.id).filter((id) => dprDisplayId(id) === search.toUpperCase())
+      if (matchIds.length === 0) matchIds = ['00000000-0000-0000-0000-000000000000']
+    } else if (UUID_RE.test(search)) {
+      matchIds = [search]
+    } else {
+      emailOrIdentifierFilter = { column: 'or', value: search }
+    }
+  }
+
+  const filterOpts = { clientId: client.id, since, until, statuses, types, priorities, assignedTo, matchIds }
+
+  let listQuery = applyFilters(
+    supabaseAdmin.from('dpr_requests').select('*', { count: 'exact' }),
+    filterOpts,
+  )
+  if (emailOrIdentifierFilter) {
+    const term = `%${emailOrIdentifierFilter.value}%`
+    listQuery = listQuery.or(`requester_email.ilike.${term},user_identifier.ilike.${term},assigned_to_name.ilike.${term}`)
+  }
+
+  const [listRes, summaryCounts, completedSample] = await Promise.all([
+    listQuery
+      .order(sortBy, { ascending: sortDir === 'asc' })
+      .range((page - 1) * pageSize, page * pageSize - 1),
+    Promise.all(STATUSES.map((status) =>
+      applyFilters(
+        supabaseAdmin.from('dpr_requests').select('*', { count: 'exact', head: true }),
+        { clientId: client.id, since, until, statuses: [status], types, priorities, assignedTo, matchIds },
+      )
+    )),
+    // Resolution-time stats — sampled over completed requests in range.
+    applyFilters(
+      supabaseAdmin.from('dpr_requests').select('created_at, completed_at').eq('status', 'completed'),
+      { clientId: client.id, since, until, types, priorities, assignedTo, matchIds },
+    ).order('completed_at', { ascending: false }).limit(5000),
+  ])
+
+  if (listRes.error) return NextResponse.json({ error: listRes.error.message }, { status: 500 })
+
+  const now = new Date()
+  const overdueRes = await applyFilters(
+    supabaseAdmin.from('dpr_requests').select('*', { count: 'exact', head: true }).neq('status', 'completed').lt('due_at', now.toISOString()),
+    { clientId: client.id, since, until, statuses, types, priorities, assignedTo, matchIds },
+  )
+
+  const summary = {
+    total: 0,
+    open: 0,
+    assigned: 0,
+    inProgress: 0,
+    completed: 0,
+    overdue: overdueRes.count || 0,
+  }
+  STATUSES.forEach((status, i) => {
+    const count = summaryCounts[i].count || 0
+    summary.total += count
+    if (status === 'open') summary.open = count
+    else if (status === 'assigned') summary.assigned = count
+    else if (status === 'in_progress') summary.inProgress = count
+    else if (status === 'completed') summary.completed = count
+  })
+
+  const resolutionHours = (completedSample.data || [])
+    .map((r) => (new Date(r.completed_at!).getTime() - new Date(r.created_at).getTime()) / 3_600_000)
+    .filter((h) => h >= 0)
+
+  const sla = {
+    avgResolutionHours: resolutionHours.length ? Math.round(resolutionHours.reduce((a, b) => a + b, 0) / resolutionHours.length) : null,
+    fastestResolutionHours: resolutionHours.length ? Math.round(Math.min(...resolutionHours)) : null,
+    slowestResolutionHours: resolutionHours.length ? Math.round(Math.max(...resolutionHours)) : null,
+  }
+
+  const records = ((listRes.data || []) as DPRRequest[]).map((r) => ({
+    id: r.id,
+    requestId: dprDisplayId(r.id),
+    requestType: r.request_type,
+    requestTypeLabel: requestTypeMeta(r.request_type).label,
+    highRisk: !!requestTypeMeta(r.request_type).highRisk,
+    requesterName: r.requester_name,
+    requesterEmail: r.requester_email,
+    userIdentifier: r.user_identifier,
+    status: r.status,
+    statusLabel: STATUS_META[r.status].label,
+    statusEmoji: STATUS_META[r.status].emoji,
+    priority: r.priority,
+    assignedTo: r.assigned_to_name,
+    createdAt: r.created_at,
+    dueAt: r.due_at,
+    completedAt: r.completed_at,
+    overdue: r.status !== 'completed' && !!r.due_at && new Date(r.due_at) < now,
+  }))
+
+  // Assignee options for the filter dropdown + assignment dropdown — pulled
+  // from this client's team plus any names already used on requests.
+  const [{ data: teamUsers }, { data: assigneeRows }] = await Promise.all([
+    supabaseAdmin.from('platform_users').select('id, name, email').eq('client_id', client.id),
+    supabaseAdmin.from('dpr_requests').select('assigned_to_name').eq('client_id', client.id).not('assigned_to_name', 'is', null),
+  ])
+  const assigneeNames = new Set<string>()
+  ;(teamUsers || []).forEach((u) => assigneeNames.add(u.name || u.email))
+  ;(assigneeRows || []).forEach((r) => { if (r.assigned_to_name) assigneeNames.add(r.assigned_to_name) })
+
+  return NextResponse.json({
+    client,
+    records,
+    count: listRes.count || 0,
+    page,
+    pageSize,
+    summary,
+    sla,
+    filters: {
+      statuses: STATUSES.map((s) => ({ value: s, ...STATUS_META[s] })),
+      types: REQUEST_TYPES.map((t) => ({ value: t.id, label: t.label, highRisk: !!t.highRisk })),
+      priorities: PRIORITIES,
+      assignees: Array.from(assigneeNames),
+    },
+    range,
+  })
+}
+
+// POST /api/dashboard/dpr-requests — staff-created request on behalf of a
+// data principal (e.g. received by phone/email rather than the web form).
+export async function POST(request: NextRequest) {
+  const params = request.nextUrl.searchParams
+  const key = params.get('key')
+  if (!key) return NextResponse.json({ error: 'key required' }, { status: 400 })
+
+  const { data: client } = await supabaseAdmin.from('clients').select('id').eq('client_key', key).single()
+  if (!client) return NextResponse.json({ error: 'Client not found' }, { status: 404 })
+
+  const ctx = await getSessionContext()
+  if (!canAccessClient(ctx, client.id)) return NextResponse.json({ error: 'Forbidden' }, { status: 403 })
+
+  const body = await request.json()
+  const { request_type, requester_name, requester_email, user_identifier, description, priority } = body
+
+  if (!request_type || !requester_email) {
+    return NextResponse.json({ error: 'request_type and requester_email required' }, { status: 400 })
+  }
+  if (!isValidRequestType(request_type)) return NextResponse.json({ error: 'Invalid request_type' }, { status: 400 })
+
+  const meta = requestTypeMeta(request_type)
+  const resolvedPriority = priority && isValidPriority(priority) ? priority : meta.defaultPriority
+  const now = new Date()
+  const dueAt = computeDueDate(now, request_type)
+
+  const { data: created, error } = await supabaseAdmin
+    .from('dpr_requests')
+    .insert({
+      client_id: client.id,
+      request_type,
+      requester_name: requester_name || null,
+      requester_email,
+      user_identifier: user_identifier || null,
+      description: description || null,
+      status: 'open',
+      priority: resolvedPriority,
+      due_at: dueAt.toISOString(),
+    })
+    .select('id')
+    .single()
+
+  if (error || !created) return NextResponse.json({ error: error?.message || 'Failed to create request' }, { status: 500 })
+
+  await supabaseAdmin.from('dpr_request_events').insert({
+    request_id: created.id,
+    event_type: 'created',
+    actor_name: ctx?.email || 'Staff',
+    actor_email: ctx?.email || null,
+    to_status: 'open',
+    message: `${meta.label} logged by staff`,
+  })
+
+  return NextResponse.json({ ok: true, id: created.id, requestId: dprDisplayId(created.id) })
+}
