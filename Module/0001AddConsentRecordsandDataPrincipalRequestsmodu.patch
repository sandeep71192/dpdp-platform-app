diff --git a/supabase/migrations/0001_data_principal_requests.sql b/supabase/migrations/0001_data_principal_requests.sql
new file mode 100644
index 0000000..f71b650
--- /dev/null
+++ b/supabase/migrations/0001_data_principal_requests.sql
@@ -0,0 +1,98 @@
+-- Data Principal Requests module (DPDP Act 2023 rights requests: access,
+-- correction, deletion, "delete my data", and future types such as consent
+-- withdrawal, nominee requests, portability, vendor objections).
+--
+-- Design notes:
+-- * request_type/status/priority are free-form `text` with app-level
+--   validation (see src/lib/dpr-requests.ts) so new request types can be
+--   added without a migration.
+-- * dpr_request_events is an append-only audit log covering the full
+--   lifecycle (creation, assignment, status changes, completion) — nothing
+--   in this module is ever deleted, only appended.
+-- * dpr_request_notes and dpr_request_assignments are likewise append-only.
+
+create extension if not exists pgcrypto;
+
+create table if not exists dpr_requests (
+  id uuid primary key default gen_random_uuid(),
+  client_id uuid not null references clients(id) on delete cascade,
+  request_type text not null,
+  requester_name text,
+  requester_email text not null,
+  user_identifier text,
+  description text,
+  status text not null default 'open',
+  priority text not null default 'medium',
+  assigned_to_user_id uuid references platform_users(id),
+  assigned_to_name text,
+  assigned_at timestamptz,
+  started_at timestamptz,
+  completed_at timestamptz,
+  due_at timestamptz,
+  resolution_notes text,
+  proof_of_completion text,
+  attachments jsonb not null default '[]'::jsonb,
+  created_at timestamptz not null default now(),
+  updated_at timestamptz not null default now(),
+  constraint dpr_requests_status_check check (status in ('open', 'assigned', 'in_progress', 'completed')),
+  constraint dpr_requests_priority_check check (priority in ('low', 'medium', 'high', 'critical'))
+);
+
+create index if not exists idx_dpr_requests_client_created on dpr_requests (client_id, created_at desc);
+create index if not exists idx_dpr_requests_client_status on dpr_requests (client_id, status);
+create index if not exists idx_dpr_requests_client_type on dpr_requests (client_id, request_type);
+create index if not exists idx_dpr_requests_client_priority on dpr_requests (client_id, priority);
+
+-- Append-only lifecycle/audit timeline (also serves as status history).
+create table if not exists dpr_request_events (
+  id uuid primary key default gen_random_uuid(),
+  request_id uuid not null references dpr_requests(id) on delete cascade,
+  event_type text not null, -- created | assigned | status_changed | note_added | completed | reassigned | priority_changed
+  actor_name text,
+  actor_email text,
+  from_status text,
+  to_status text,
+  message text,
+  metadata jsonb not null default '{}'::jsonb,
+  created_at timestamptz not null default now()
+);
+
+create index if not exists idx_dpr_request_events_request on dpr_request_events (request_id, created_at);
+
+-- Internal staff notes (append-only).
+create table if not exists dpr_request_notes (
+  id uuid primary key default gen_random_uuid(),
+  request_id uuid not null references dpr_requests(id) on delete cascade,
+  author_name text,
+  author_email text,
+  note text not null,
+  created_at timestamptz not null default now()
+);
+
+create index if not exists idx_dpr_request_notes_request on dpr_request_notes (request_id, created_at);
+
+-- Assignment history (append-only) — current assignee is also denormalized
+-- onto dpr_requests for fast filtering/listing.
+create table if not exists dpr_request_assignments (
+  id uuid primary key default gen_random_uuid(),
+  request_id uuid not null references dpr_requests(id) on delete cascade,
+  assigned_to_user_id uuid references platform_users(id),
+  assigned_to_name text not null,
+  assigned_by_email text,
+  created_at timestamptz not null default now()
+);
+
+create index if not exists idx_dpr_request_assignments_request on dpr_request_assignments (request_id, created_at);
+
+-- Keep updated_at current on every mutation.
+create or replace function dpr_set_updated_at() returns trigger as $$
+begin
+  new.updated_at = now();
+  return new;
+end;
+$$ language plpgsql;
+
+drop trigger if exists trg_dpr_requests_updated_at on dpr_requests;
+create trigger trg_dpr_requests_updated_at
+  before update on dpr_requests
+  for each row execute function dpr_set_updated_at();
-- 
