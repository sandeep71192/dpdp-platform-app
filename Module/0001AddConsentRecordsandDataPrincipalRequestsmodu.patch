+'use client'
+import { useState, useEffect, useCallback } from 'react'
+import { useParams } from 'next/navigation'
+import Link from 'next/link'
+import DPRTimeline, { TimelineEvent } from '@/components/portal/dpr/DPRTimeline'
+import DPRNotesPanel, { NoteItem } from '@/components/portal/dpr/DPRNotesPanel'
+import DPRActionsPanel from '@/components/portal/dpr/DPRActionsPanel'
+import { PRIORITY_META } from '@/lib/dpr-requests'
+import type { DPRStatus, DPRPriority } from '@/types/database'
+
+interface RequestDetail {
+  id: string
+  requestId: string
+  requestType: string
+  requestTypeLabel: string
+  requestTypeDescription: string
+  highRisk: boolean
+  requesterName: string | null
+  requesterEmail: string
+  userIdentifier: string | null
+  description: string | null
+  status: DPRStatus
+  statusLabel: string
+  statusEmoji: string
+  priority: DPRPriority
+  assignedToName: string | null
+  assignedToUserId: string | null
+  assignedAt: string | null
+  startedAt: string | null
+  completedAt: string | null
+  dueAt: string | null
+  overdue: boolean
+  resolutionNotes: string | null
+  proofOfCompletion: string | null
+  attachments: unknown
+  createdAt: string
+  updatedAt: string
+}
+
+function formatDate(value: string | null) {
+  if (!value) return '—'
+  return new Date(value).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Kolkata' })
+}
+
+export default function RequestDetailPage() {
+  const { clientKey, id } = useParams<{ clientKey: string; id: string }>()
+
+  const [request, setRequest] = useState<RequestDetail | null>(null)
+  const [timeline, setTimeline] = useState<TimelineEvent[]>([])
+  const [notes, setNotes] = useState<NoteItem[]>([])
+  const [assignees, setAssignees] = useState<string[]>([])
+  const [loading, setLoading] = useState(true)
+  const [error, setError] = useState<string | null>(null)
+
+  const load = useCallback(() => {
+    return fetch(`/api/dashboard/dpr-requests/${id}?key=${clientKey}`)
+      .then((r) => r.json())
+      .then((d) => {
+        if (d.error) throw new Error(d.error)
+        setRequest(d.request)
+        setTimeline(d.timeline)
+        setNotes(d.notes)
+        setError(null)
+      })
+      .catch((e) => setError(e.message || 'Could not load request.'))
+      .finally(() => setLoading(false))
+  }, [id, clientKey])
+
+  useEffect(() => {
+    load()
+  }, [load])
+
+  useEffect(() => {
+    fetch(`/api/dashboard/dpr-requests?key=${clientKey}&pageSize=1`)
+      .then((r) => r.json())
+      .then((d) => { if (d.filters?.assignees) setAssignees(d.filters.assignees) })
+      .catch(() => {})
+  }, [clientKey])
+
+  function patch(body: object) {
+    return fetch(`/api/dashboard/dpr-requests/${id}?key=${clientKey}`, {
+      method: 'PATCH',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify(body),
+    })
+      .then((r) => r.json())
+      .then((d) => {
+        if (d.error) throw new Error(d.error)
+        return load()
+      })
+  }
+
+  if (loading) {
+    return <div className="p-8 text-sm text-zinc-500">Loading request…</div>
+  }
+
+  if (error || !request) {
+    return (
+      <div className="p-8">
+        <div className="bg-red-500/5 border border-red-500/20 rounded-2xl p-4 text-sm text-red-500">{error || 'Request not found.'}</div>
+        <Link href={`/portal/${clientKey}/requests`} className="inline-block mt-4 text-sm text-violet-600 font-semibold hover:underline">← Back to Requests</Link>
+      </div>
+    )
+  }
+
+  const attachments = Array.isArray(request.attachments) ? request.attachments as string[] : []
+
+  return (
+    <div className="p-8 max-w-6xl">
+      <Link href={`/portal/${clientKey}/requests`} className="inline-block mb-4 text-sm text-violet-600 font-semibold hover:underline">← Back to Requests</Link>
+
+      <div className="mb-6 flex items-start justify-between gap-4 flex-wrap">
+        <div>
+          <div className="flex items-center gap-2">
+            <h1 className="text-2xl font-bold text-[#1b1b29] tracking-tight">{request.requestId}</h1>
+            {request.highRisk && (
+              <span className="text-xs font-semibold px-2 py-0.5 rounded-lg bg-red-500/10 text-red-500 border border-red-500/20">⚠️ High Risk</span>
+            )}
+            {request.overdue && (
+              <span className="text-xs font-semibold px-2 py-0.5 rounded-lg bg-orange-500/10 text-orange-500 border border-orange-500/20">⚠️ Overdue</span>
+            )}
+          </div>
+          <p className="text-sm text-zinc-500 mt-1">{request.requestTypeLabel} · {request.requestTypeDescription}</p>
+        </div>
+        <div className="flex items-center gap-2">
+          <span className={`text-xs font-semibold px-3 py-1.5 rounded-lg capitalize ${PRIORITY_META[request.priority].color} bg-violet-500/10 border border-violet-500/30`}>
+            {PRIORITY_META[request.priority].label} Priority
+          </span>
+          <span className="text-xs font-semibold px-3 py-1.5 rounded-lg bg-black/[0.04] text-[#1b1b29]">
+            {request.statusEmoji} {request.statusLabel}
+          </span>
+        </div>
+      </div>
+
+      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
+        <div className="lg:col-span-2 space-y-6">
+          <section className="bg-white border border-[#e8e8ee] rounded-2xl p-5">
+            <h2 className="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-3">Requester Details</h2>
+            <dl className="grid grid-cols-2 gap-4 text-sm">
+              <div>
+                <dt className="text-xs text-zinc-400">Name</dt>
+                <dd className="text-[#1b1b29] font-medium">{request.requesterName || '—'}</dd>
+              </div>
+              <div>
+                <dt className="text-xs text-zinc-400">Email</dt>
+                <dd className="text-[#1b1b29] font-medium">{request.requesterEmail}</dd>
+              </div>
+              <div>
+                <dt className="text-xs text-zinc-400">User Identifier</dt>
+                <dd className="text-[#1b1b29] font-medium">{request.userIdentifier || '—'}</dd>
+              </div>
+              <div>
+                <dt className="text-xs text-zinc-400">Submitted</dt>
+                <dd className="text-[#1b1b29] font-medium">{formatDate(request.createdAt)}</dd>
+              </div>
+              <div>
+                <dt className="text-xs text-zinc-400">Due By</dt>
+                <dd className={`font-medium ${request.overdue ? 'text-orange-500' : 'text-[#1b1b29]'}`}>{formatDate(request.dueAt)}</dd>
+              </div>
+              <div>
+                <dt className="text-xs text-zinc-400">Assigned To</dt>
+                <dd className="text-[#1b1b29] font-medium">{request.assignedToName || 'Unassigned'}</dd>
+              </div>
+            </dl>
+            {request.description && (
+              <div className="mt-4">
+                <dt className="text-xs text-zinc-400 mb-1">Description</dt>
+                <dd className="text-sm text-zinc-700 whitespace-pre-wrap bg-black/[0.02] rounded-xl p-3">{request.description}</dd>
+              </div>
+            )}
+          </section>
+
+          {request.status === 'completed' && (
+            <section className="bg-green-500/5 border border-green-500/20 rounded-2xl p-5">
+              <h2 className="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-3">Resolution Details</h2>
+              <dl className="space-y-3 text-sm">
+                <div>
+                  <dt className="text-xs text-zinc-400">Completed</dt>
+                  <dd className="text-[#1b1b29] font-medium">{formatDate(request.completedAt)}</dd>
+                </div>
+                <div>
+                  <dt className="text-xs text-zinc-400 mb-1">Resolution Notes</dt>
+                  <dd className="text-zinc-700 whitespace-pre-wrap">{request.resolutionNotes || '—'}</dd>
+                </div>
+                <div>
+                  <dt className="text-xs text-zinc-400 mb-1">Proof of Completion</dt>
+                  <dd className="text-zinc-700 whitespace-pre-wrap">{request.proofOfCompletion || '—'}</dd>
+                </div>
+              </dl>
+            </section>
+          )}
+
+          <section className="bg-white border border-[#e8e8ee] rounded-2xl p-5">
+            <h2 className="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-3">Attachments</h2>
+            {attachments.length === 0 ? (
+              <p className="text-sm text-zinc-500">No attachments.</p>
+            ) : (
+              <ul className="space-y-1.5 text-sm">
+                {attachments.map((a, i) => (
+                  <li key={i} className="text-violet-600 truncate">{a}</li>
+                ))}
+              </ul>
+            )}
+          </section>
+
+          <section className="bg-white border border-[#e8e8ee] rounded-2xl p-5">
+            <h2 className="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-3">Internal Notes</h2>
+            <DPRNotesPanel notes={notes} onAddNote={(note) => patch({ action: 'note', note })} />
+          </section>
+
+          <section className="bg-white border border-[#e8e8ee] rounded-2xl p-5">
+            <h2 className="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-3">Timeline</h2>
+            <DPRTimeline events={timeline} />
+          </section>
+        </div>
+
+        <div className="space-y-6">
+          <section className="bg-white border border-[#e8e8ee] rounded-2xl p-5">
+            <h2 className="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-3">Workflow Actions</h2>
+            <DPRActionsPanel
+              status={request.status}
+              assignedToName={request.assignedToName}
+              priority={request.priority}
+              assignees={assignees}
+              onAssign={(name) => patch({ action: 'assign', assignedToName: name })}
+              onStatusChange={(status, resolutionNotes, proof) => patch({ action: 'status', status, resolutionNotes, proofOfCompletion: proof })}
+              onPriorityChange={(priority) => patch({ action: 'priority', priority })}
+            />
+          </section>
+        </div>
+      </div>
+    </div>
+  )
+}
