+'use client'
+import { useState } from 'react'
+import RangeFilter, { RangeKey } from '@/components/portal/RangeFilter'
+import { PRIORITY_META } from '@/lib/dpr-requests'
+import type { DPRPriority } from '@/types/database'
+
+export interface StatusOption { value: string; label: string; emoji: string }
+export interface TypeOption { value: string; label: string; highRisk: boolean }
+
+interface FiltersProps {
+  range: RangeKey
+  from: string
+  to: string
+  onRangeChange: (range: RangeKey, from?: string, to?: string) => void
+  statusOptions: StatusOption[]
+  selectedStatuses: string[]
+  onStatusToggle: (status: string) => void
+  typeOptions: TypeOption[]
+  selectedTypes: string[]
+  onTypeToggle: (type: string) => void
+  priorities: DPRPriority[]
+  selectedPriorities: string[]
+  onPriorityToggle: (priority: string) => void
+  assignees: string[]
+  assignedTo: string
+  onAssignedToChange: (assignee: string) => void
+  search: string
+  onSearchChange: (search: string) => void
+}
+
+export default function DPRFilters({
+  range, from, to, onRangeChange,
+  statusOptions, selectedStatuses, onStatusToggle,
+  typeOptions, selectedTypes, onTypeToggle,
+  priorities, selectedPriorities, onPriorityToggle,
+  assignees, assignedTo, onAssignedToChange,
+  search, onSearchChange,
+}: FiltersProps) {
+  const [searchInput, setSearchInput] = useState(search)
+
+  return (
+    <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4 mb-6 space-y-3">
+      <div className="flex items-start justify-between gap-4 flex-wrap">
+        <RangeFilter range={range} from={from} to={to} onChange={onRangeChange} />
+        <form onSubmit={(e) => { e.preventDefault(); onSearchChange(searchInput) }} className="flex items-center gap-2">
+          <input
+            type="text"
+            value={searchInput}
+            onChange={(e) => setSearchInput(e.target.value)}
+            placeholder="Search by Request ID, Email, User ID, Assignee…"
+            className="text-xs px-3 py-1.5 rounded-lg border border-[#e8e8ee] bg-white text-zinc-700 w-64"
+          />
+          <button type="submit" className="text-xs px-3 py-1.5 rounded-lg bg-violet-600 text-white font-medium hover:bg-violet-500 transition-colors">Search</button>
+          {search && (
+            <button type="button" onClick={() => { setSearchInput(''); onSearchChange('') }} className="text-xs px-3 py-1.5 rounded-lg bg-black/[0.04] text-zinc-500 hover:text-[#1b1b29] font-medium transition-colors">Clear</button>
+          )}
+        </form>
+      </div>
+
+      <div className="flex items-center gap-4 flex-wrap">
+        <div className="flex items-center gap-1.5 flex-wrap">
+          <span className="text-xs text-zinc-500 mr-1">Status:</span>
+          {statusOptions.map((s) => {
+            const active = selectedStatuses.includes(s.value)
+            return (
+              <button key={s.value} onClick={() => onStatusToggle(s.value)}
+                className={`text-xs px-2.5 py-1 rounded-lg font-medium transition-colors ${active ? 'bg-violet-500/10 text-violet-600 border border-violet-500/30' : 'bg-black/[0.04] text-zinc-500 hover:text-[#1b1b29] border border-transparent'}`}>
+                {s.emoji} {s.label}
+              </button>
+            )
+          })}
+        </div>
+
+        <div className="flex items-center gap-1.5 flex-wrap">
+          <span className="text-xs text-zinc-500 mr-1">Priority:</span>
+          {priorities.map((p) => {
+            const active = selectedPriorities.includes(p)
+            return (
+              <button key={p} onClick={() => onPriorityToggle(p)}
+                className={`text-xs px-2.5 py-1 rounded-lg font-medium capitalize transition-colors ${active ? `bg-violet-500/10 ${PRIORITY_META[p].color} border border-violet-500/30` : 'bg-black/[0.04] text-zinc-500 hover:text-[#1b1b29] border border-transparent'}`}>
+                {PRIORITY_META[p].label}
+              </button>
+            )
+          })}
+        </div>
+      </div>
+
+      <div className="flex items-center gap-4 flex-wrap">
+        <div className="flex items-center gap-1.5 flex-wrap">
+          <span className="text-xs text-zinc-500 mr-1">Type:</span>
+          {typeOptions.map((t) => {
+            const active = selectedTypes.includes(t.value)
+            return (
+              <button key={t.value} onClick={() => onTypeToggle(t.value)}
+                className={`text-xs px-2.5 py-1 rounded-lg font-medium transition-colors ${active ? 'bg-violet-500/10 text-violet-600 border border-violet-500/30' : 'bg-black/[0.04] text-zinc-500 hover:text-[#1b1b29] border border-transparent'}`}>
+                {t.highRisk && '⚠️ '}{t.label}
+              </button>
+            )
+          })}
+        </div>
+
+        {assignees.length > 0 && (
+          <select value={assignedTo} onChange={(e) => onAssignedToChange(e.target.value)} className="text-xs px-2.5 py-1.5 rounded-lg border border-[#e8e8ee] bg-white text-zinc-700">
+            <option value="">All Assignees</option>
+            {assignees.map((a) => <option key={a} value={a}>{a}</option>)}
+          </select>
+        )}
+      </div>
+    </div>
+  )
+}
diff --git a/src/components/portal/dpr/DPRNotesPanel.tsx b/src/components/portal/dpr/DPRNotesPanel.tsx
new file mode 100644
index 0000000..405fc1e
--- /dev/null
+++ b/src/components/portal/dpr/DPRNotesPanel.tsx
@@ -0,0 +1,53 @@
+'use client'
+import { useState } from 'react'
+
+export interface NoteItem {
+  id: string
+  author_name: string | null
+  note: string
+  created_at: string
+}
+
+export default function DPRNotesPanel({ notes, onAddNote }: { notes: NoteItem[]; onAddNote: (note: string) => Promise<void> }) {
+  const [text, setText] = useState('')
+  const [submitting, setSubmitting] = useState(false)
+
+  function handleSubmit(e: React.FormEvent) {
+    e.preventDefault()
+    if (!text.trim()) return
+    setSubmitting(true)
+    onAddNote(text.trim()).then(() => setText('')).finally(() => setSubmitting(false))
+  }
+
+  return (
+    <div className="space-y-3">
+      {notes.length === 0 ? (
+        <p className="text-sm text-zinc-500">No internal notes yet.</p>
+      ) : (
+        <div className="space-y-3">
+          {notes.map((n) => (
+            <div key={n.id} className="bg-black/[0.02] rounded-xl p-3">
+              <p className="text-sm text-zinc-700 whitespace-pre-wrap">{n.note}</p>
+              <div className="text-xs text-zinc-400 mt-1.5">
+                {n.author_name || 'Staff'} · {new Date(n.created_at).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Kolkata' })}
+              </div>
+            </div>
+          ))}
+        </div>
+      )}
+
+      <form onSubmit={handleSubmit} className="flex gap-2">
+        <textarea
+          value={text}
+          onChange={(e) => setText(e.target.value)}
+          placeholder='e.g. "Verified identity before processing."'
+          rows={2}
+          className="flex-1 text-sm px-3 py-2 rounded-xl border border-[#e8e8ee] bg-white text-zinc-700 resize-none"
+        />
+        <button type="submit" disabled={submitting || !text.trim()} className="px-3 py-2 bg-violet-600 hover:bg-violet-500 disabled:opacity-50 text-white text-xs font-semibold rounded-xl transition-colors self-end">
+          Add Note
+        </button>
+      </form>
+    </div>
+  )
+}
