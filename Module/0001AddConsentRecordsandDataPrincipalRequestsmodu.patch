@@ -0,0 +1,126 @@
+import { PRIORITY_META } from '@/lib/dpr-requests'
+import type { DPRPriority } from '@/types/database'
+
+export interface DPRListItem {
+  id: string
+  requestId: string
+  requestType: string
+  requestTypeLabel: string
+  highRisk: boolean
+  requesterName: string | null
+  requesterEmail: string
+  userIdentifier: string | null
+  status: string
+  statusLabel: string
+  statusEmoji: string
+  priority: DPRPriority
+  assignedTo: string | null
+  createdAt: string
+  dueAt: string | null
+  completedAt: string | null
+  overdue: boolean
+}
+
+interface SortableHeader {
+  key: string
+  label: string
+  sortable: boolean
+}
+
+const HEADERS: SortableHeader[] = [
+  { key: 'request_id', label: 'Request ID', sortable: false },
+  { key: 'request_type', label: 'Request Type', sortable: true },
+  { key: 'requester', label: 'User', sortable: false },
+  { key: 'created_at', label: 'Submitted', sortable: true },
+  { key: 'status', label: 'Status', sortable: true },
+  { key: 'assigned_to', label: 'Assigned To', sortable: false },
+  { key: 'priority', label: 'Priority', sortable: true },
+]
+
+interface TableProps {
+  records: DPRListItem[]
+  loading: boolean
+  sortBy: string
+  sortDir: 'asc' | 'desc'
+  onSort: (col: string) => void
+  selected: Set<string>
+  onToggleSelect: (id: string) => void
+  onToggleSelectAll: () => void
+  onRowClick: (id: string) => void
+}
+
+export default function DPRTable({ records, loading, sortBy, sortDir, onSort, selected, onToggleSelect, onToggleSelectAll, onRowClick }: TableProps) {
+  const allSelected = records.length > 0 && records.every((r) => selected.has(r.id))
+
+  if (loading) {
+    return (
+      <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl overflow-hidden">
+        <div className="p-6 space-y-3">
+          {[0, 1, 2, 3, 4].map((i) => <div key={i} className="h-10 bg-black/[0.04] rounded animate-pulse" />)}
+        </div>
+      </div>
+    )
+  }
+
+  if (records.length === 0) {
+    return (
+      <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-16 text-center">
+        <div className="text-5xl mb-4">📨</div>
+        <h3 className="text-base font-semibold text-[#1b1b29] mb-2">No requests found</h3>
+        <p className="text-sm text-zinc-500">Try adjusting your filters or date range.</p>
+      </div>
+    )
+  }
+
+  return (
+    <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl overflow-hidden">
+      <div className="overflow-x-auto">
+        <table className="w-full">
+          <thead className="sticky top-0 bg-[#ffffff] z-10">
+            <tr className="border-b border-[#e8e8ee]">
+              <th className="px-5 py-3 w-10">
+                <input type="checkbox" checked={allSelected} onChange={onToggleSelectAll} className="rounded" />
+              </th>
+              {HEADERS.map((h) => (
+                <th key={h.key} onClick={() => h.sortable && onSort(h.key)}
+                  className={`text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider px-5 py-3 whitespace-nowrap ${h.sortable ? 'cursor-pointer hover:text-[#1b1b29]' : ''}`}>
+                  {h.label}
+                  {h.sortable && sortBy === h.key && (sortDir === 'asc' ? ' ▲' : ' ▼')}
+                </th>
+              ))}
+            </tr>
+          </thead>
+          <tbody>
+            {records.map((r) => (
+              <tr key={r.id} onClick={() => onRowClick(r.id)} className="border-b border-[#e8e8ee] last:border-0 hover:bg-black/[0.02] cursor-pointer">
+                <td className="px-5 py-3" onClick={(e) => e.stopPropagation()}>
+                  <input type="checkbox" checked={selected.has(r.id)} onChange={() => onToggleSelect(r.id)} className="rounded" />
+                </td>
+                <td className="px-5 py-3 text-xs font-mono font-semibold text-violet-600 whitespace-nowrap">{r.requestId}</td>
+                <td className="px-5 py-3 text-xs text-zinc-700 whitespace-nowrap">
+                  {r.highRisk && <span title="High priority deletion request" className="mr-1">⚠️</span>}
+                  {r.requestTypeLabel}
+                </td>
+                <td className="px-5 py-3 text-xs text-zinc-500">
+                  <div className="font-medium text-zinc-700">{r.requesterName || '—'}</div>
+                  <div>{r.requesterEmail}</div>
+                </td>
+                <td className="px-5 py-3 text-xs text-zinc-500 font-mono whitespace-nowrap">
+                  {new Date(r.createdAt).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Kolkata' })}
+                </td>
+                <td className="px-5 py-3">
+                  <span className="text-xs font-medium">{r.statusEmoji} {r.statusLabel}</span>
+                  {r.overdue && <div className="text-[10px] text-red-500 font-semibold mt-0.5">⚠️ Overdue</div>}
+                </td>
+                <td className="px-5 py-3 text-xs text-zinc-500">{r.assignedTo || '—'}</td>
+                <td className="px-5 py-3">
+                  <span className={`text-xs font-semibold capitalize ${PRIORITY_META[r.priority].color}`}>{PRIORITY_META[r.priority].label}</span>
+                </td>
+              </tr>
+            ))}
+          </tbody>
+        </table>
+      </div>
+    </div>
+  )
+}
