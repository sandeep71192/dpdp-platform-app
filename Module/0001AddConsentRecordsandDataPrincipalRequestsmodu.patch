new file mode 100644
index 0000000..e8cefec
--- /dev/null
+++ b/src/lib/dpr-requests.ts
@@ -0,0 +1,132 @@
+import type { DPRPriority, DPRStatus } from '@/types/database'
+
+// Request type catalogue. New types (consent withdrawal, nominee requests,
+// data portability, vendor objections, automated deletion, ...) can be added
+// here without any DB migration — request_type is stored as free text and
+// validated against this list at the API boundary.
+export interface RequestTypeMeta {
+  id: string
+  label: string
+  description: string
+  defaultPriority: DPRPriority
+  highRisk?: boolean
+  slaDays: number
+}
+
+export const REQUEST_TYPES: RequestTypeMeta[] = [
+  {
+    id: 'access',
+    label: 'Access Request',
+    description: 'View profile information, consent history, and collected data.',
+    defaultPriority: 'medium',
+    slaDays: 30,
+  },
+  {
+    id: 'correction',
+    label: 'Correction Request',
+    description: 'Update or correct profile details such as email or phone.',
+    defaultPriority: 'medium',
+    slaDays: 30,
+  },
+  {
+    id: 'deletion',
+    label: 'Deletion Request',
+    description: 'Delete specific personal data — account info, documents, or preferences.',
+    defaultPriority: 'medium',
+    slaDays: 30,
+  },
+  {
+    id: 'delete_my_data',
+    label: 'Delete My Data Request',
+    description: 'Delete all personal data associated with the requester. High priority.',
+    defaultPriority: 'high',
+    highRisk: true,
+    slaDays: 30,
+  },
+]
+
+export const REQUEST_TYPE_IDS = REQUEST_TYPES.map((t) => t.id)
+
+export function requestTypeMeta(id: string): RequestTypeMeta {
+  return REQUEST_TYPES.find((t) => t.id === id) || {
+    id,
+    label: humanizeRequestType(id),
+    description: '',
+    defaultPriority: 'medium',
+    slaDays: 30,
+  }
+}
+
+export function humanizeRequestType(id: string): string {
+  return id.replace(/_/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())
+}
+
+export function isValidRequestType(value: string): boolean {
+  // Accept catalogued types plus any future type as long as it's a sane slug —
+  // keeps this future-ready without requiring a code change for new types.
+  return /^[a-z][a-z0-9_]{1,40}$/.test(value)
+}
+
+export const STATUSES: DPRStatus[] = ['open', 'assigned', 'in_progress', 'completed']
+
+export const STATUS_META: Record<DPRStatus, { label: string; emoji: string }> = {
+  open: { label: 'Open', emoji: '🔵' },
+  assigned: { label: 'Assigned', emoji: '🟣' },
+  in_progress: { label: 'In Progress', emoji: '🟡' },
+  completed: { label: 'Completed', emoji: '🟢' },
+}
+
+export function isValidStatus(value: string): value is DPRStatus {
+  return (STATUSES as string[]).includes(value)
+}
+
+export const PRIORITIES: DPRPriority[] = ['low', 'medium', 'high', 'critical']
+
+export const PRIORITY_META: Record<DPRPriority, { label: string; color: string }> = {
+  low: { label: 'Low', color: 'text-zinc-500' },
+  medium: { label: 'Medium', color: 'text-blue-500' },
+  high: { label: 'High', color: 'text-amber-500' },
+  critical: { label: 'Critical', color: 'text-red-500' },
+}
+
+export function isValidPriority(value: string): value is DPRPriority {
+  return (PRIORITIES as string[]).includes(value)
+}
+
+// Valid forward status transitions. Assignment can happen from `open` (->
+// `assigned`); work can start from `open` or `assigned` (-> `in_progress`);
+// completion can happen from any non-terminal status.
+export const STATUS_TRANSITIONS: Record<DPRStatus, DPRStatus[]> = {
+  open: ['assigned', 'in_progress', 'completed'],
+  assigned: ['in_progress', 'completed'],
+  in_progress: ['completed'],
+  completed: [],
+}
+
+export function canTransition(from: DPRStatus, to: DPRStatus): boolean {
+  return from === to || STATUS_TRANSITIONS[from]?.includes(to)
+}
+
+// Derives a stable "DPR-XXXXXX" display ID from a request's UUID, mirroring
+// the consent ledger's DPDP-XXXXXX display IDs.
+export function dprDisplayId(id: string): string {
+  const hex = id.replace(/-/g, '').slice(0, 8)
+  const num = parseInt(hex, 16) % 1_000_000
+  return `DPR-${num.toString().padStart(6, '0')}`
+}
+
+export function computeDueDate(createdAt: Date, requestType: string): Date {
+  const meta = requestTypeMeta(requestType)
+  const due = new Date(createdAt)
+  due.setDate(due.getDate() + meta.slaDays)
+  return due
+}
+
+export const SORTABLE_COLUMNS = ['created_at', 'status', 'priority', 'request_type', 'due_at'] as const
+export type SortableColumn = typeof SORTABLE_COLUMNS[number]
+
+export function isSortableColumn(value: string): value is SortableColumn {
+  return (SORTABLE_COLUMNS as readonly string[]).includes(value)
+}
+
+export const PAGE_SIZES = [25, 50, 100] as const
