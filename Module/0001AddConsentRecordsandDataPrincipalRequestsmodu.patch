+
+const EVENT_ICONS: Record<string, string> = {
+  created: '📨',
+  assigned: '🟣',
+  reassigned: '🔁',
+  status_changed: '🔄',
+  note_added: '📝',
+  completed: '🟢',
+  priority_changed: '⚡',
