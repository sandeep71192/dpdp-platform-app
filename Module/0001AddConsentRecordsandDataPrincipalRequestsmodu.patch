@@ -0,0 +1,113 @@
+'use client'
+import { useState } from 'react'
+import { STATUS_TRANSITIONS, STATUS_META, PRIORITIES, PRIORITY_META } from '@/lib/dpr-requests'
+import type { DPRStatus, DPRPriority } from '@/types/database'
+
+interface ActionsPanelProps {
+  status: DPRStatus
+  assignedToName: string | null
+  priority: DPRPriority
+  assignees: string[]
+  onAssign: (name: string) => Promise<void>
+  onStatusChange: (status: DPRStatus, resolutionNotes?: string, proof?: string) => Promise<void>
+  onPriorityChange: (priority: string) => Promise<void>
+}
+
+export default function DPRActionsPanel({ status, assignedToName, priority, assignees, onAssign, onStatusChange, onPriorityChange }: ActionsPanelProps) {
+  const [assignee, setAssignee] = useState(assignedToName || '')
+  const [resolutionNotes, setResolutionNotes] = useState('')
+  const [proof, setProof] = useState('')
+  const [busy, setBusy] = useState(false)
+  const [showComplete, setShowComplete] = useState(false)
+
+  const nextStatuses = STATUS_TRANSITIONS[status]
+
+  function runAssign() {
+    if (!assignee.trim()) return
+    setBusy(true)
+    onAssign(assignee.trim()).finally(() => setBusy(false))
+  }
+
+  function runStatusChange(next: DPRStatus) {
+    if (next === 'completed') {
+      setShowComplete(true)
+      return
+    }
+    setBusy(true)
+    onStatusChange(next).finally(() => setBusy(false))
+  }
+
+  function submitCompletion(e: React.FormEvent) {
+    e.preventDefault()
+    setBusy(true)
+    onStatusChange('completed', resolutionNotes, proof).finally(() => setBusy(false))
+  }
+
+  return (
+    <div className="space-y-4">
+      <div>
+        <label className="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Assigned To</label>
+        <div className="flex gap-2">
+          <input
+            value={assignee}
+            onChange={(e) => setAssignee(e.target.value)}
+            list="dpr-assignees"
+            placeholder="e.g. Compliance Officer"
+            className="flex-1 text-sm px-3 py-2 rounded-xl border border-[#e8e8ee] bg-white text-zinc-700"
+          />
+          <datalist id="dpr-assignees">
+            {assignees.map((a) => <option key={a} value={a} />)}
+          </datalist>
+          <button onClick={runAssign} disabled={busy || !assignee.trim() || assignee.trim() === assignedToName}
+            className="px-3 py-2 bg-violet-600 hover:bg-violet-500 disabled:opacity-50 text-white text-xs font-semibold rounded-xl transition-colors">
+            {assignedToName ? 'Reassign' : 'Assign'}
+          </button>
+        </div>
+      </div>
+
+      <div>
+        <label className="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Priority</label>
+        <div className="flex gap-1.5">
+          {PRIORITIES.map((p) => (
+            <button key={p} onClick={() => onPriorityChange(p)} disabled={busy || p === priority}
+              className={`text-xs px-2.5 py-1.5 rounded-lg font-medium capitalize transition-colors ${p === priority ? `bg-violet-500/10 ${PRIORITY_META[p].color} border border-violet-500/30` : 'bg-black/[0.04] text-zinc-500 hover:text-[#1b1b29] border border-transparent'}`}>
+              {PRIORITY_META[p].label}
+            </button>
+          ))}
+        </div>
+      </div>
+
+      {nextStatuses.length > 0 && (
+        <div>
+          <label className="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Move To</label>
+          <div className="flex gap-1.5 flex-wrap">
+            {nextStatuses.map((s) => (
+              <button key={s} onClick={() => runStatusChange(s)} disabled={busy}
+                className="text-xs px-3 py-1.5 rounded-lg font-medium bg-violet-600 hover:bg-violet-500 disabled:opacity-50 text-white transition-colors">
+                {STATUS_META[s].emoji} {STATUS_META[s].label}
+              </button>
+            ))}
+          </div>
+        </div>
+      )}
+
+      {showComplete && (
+        <form onSubmit={submitCompletion} className="bg-green-500/5 border border-green-500/20 rounded-xl p-4 space-y-3">
+          <h3 className="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Complete Request</h3>
+          <div>
+            <label className="block text-xs text-zinc-500 mb-1">Resolution Notes</label>
+            <textarea value={resolutionNotes} onChange={(e) => setResolutionNotes(e.target.value)} rows={3} className="w-full text-sm px-3 py-2 rounded-xl border border-[#e8e8ee] bg-white text-zinc-700 resize-none" />
+          </div>
+          <div>
+            <label className="block text-xs text-zinc-500 mb-1">Proof of Completion (link or reference)</label>
+            <input value={proof} onChange={(e) => setProof(e.target.value)} className="w-full text-sm px-3 py-2 rounded-xl border border-[#e8e8ee] bg-white text-zinc-700" />
+          </div>
+          <div className="flex gap-2">
+            <button type="submit" disabled={busy} className="px-4 py-2 bg-green-600 hover:bg-green-500 disabled:opacity-50 text-white text-xs font-semibold rounded-xl transition-colors">Mark Completed</button>
+            <button type="button" onClick={() => setShowComplete(false)} className="px-4 py-2 bg-black/[0.04] hover:bg-black/[0.08] text-zinc-500 text-xs font-semibold rounded-xl transition-colors">Cancel</button>
+          </div>
+        </form>
+      )}
+    </div>
+  )
+}
