-+
-+  const { data: client } = await supabaseAdmin
-+    .from('clients')
-+    .select('id, name, domain')
-+    .eq('client_key', key)
-+    .single()
-+
-+  if (!client) return NextResponse.json({ error: 'Client not found' }, { status: 404 })
-+
-+  const ctx = await getSessionContext()
-+  if (!canAccessClient(ctx, client.id)) return NextResponse.json({ error: 'Forbidden' }, { status: 403 })
-+
-+  const format = params.get('format') || 'csv'
-+  const scope = params.get('scope') || 'filtered'
-+
-+  const range = params.get('range') || '30d'
-+  const from = params.get('from')
-+  const to = params.get('to')
-+  const { since, until } = resolveRange(range, from, to)
-+
-+  const statuses = (params.get('status') || '').split(',').map((s) => s.trim()).filter(Boolean)
-+  const purpose = params.get('purpose')
-+  const language = params.get('language')
-+  const search = params.get('search')
-+  const ids = (params.get('ids') || '').split(',').map((s) => s.trim()).filter(Boolean)
-+
-+  const columns = 'id, created_at, event_type, consented_to, language_used, device_type, country, page_url, session_id'
-+
-+  let rows: ExportRow[] = []
-+  let truncated = false
-+  let filterCriteria: string
-+
-+  if (scope === 'selected') {
-+    if (ids.length === 0) return NextResponse.json({ error: 'ids required for selected export' }, { status: 400 })
-+    const { data, error } = await supabaseAdmin
-+      .from('consent_events')
-+      .select(columns)
-+      .eq('client_id', client.id)
-+      .in('id', ids)
-+    if (error) return NextResponse.json({ error: error.message }, { status: 500 })
-+    rows = (data || []) as unknown as ExportRow[]
-+    filterCriteria = `Selected records (${ids.length})`
-+  } else {
-+    let filterOpts: Parameters<typeof applyRecordFilters>[1]
-+    if (scope === 'all') {
-+      filterOpts = { clientId: client.id, since: new Date(0), until: new Date() }
-+      filterCriteria = 'All records'
-+    } else if (scope === 'range') {
-+      filterOpts = { clientId: client.id, since, until }
