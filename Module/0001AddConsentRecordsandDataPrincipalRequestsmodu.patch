@@ -0,0 +1,73 @@
+export interface DPRSummary {
+  total: number
+  open: number
+  assigned: number
+  inProgress: number
+  completed: number
+  overdue: number
+}
+
+export interface DPRSla {
+  avgResolutionHours: number | null
+  fastestResolutionHours: number | null
+  slowestResolutionHours: number | null
+}
+
+function formatHours(hours: number | null): string {
+  if (hours === null) return '—'
+  if (hours < 24) return `${hours}h`
+  return `${(hours / 24).toFixed(1)}d`
+}
+
+const CARDS: { key: keyof DPRSummary; label: string; emoji: string; color: string }[] = [
+  { key: 'total', label: 'Total Requests', emoji: '📨', color: 'text-[#1b1b29]' },
+  { key: 'open', label: 'Open', emoji: '🔵', color: 'text-blue-500' },
+  { key: 'inProgress', label: 'In Progress', emoji: '🟡', color: 'text-amber-500' },
+  { key: 'completed', label: 'Completed', emoji: '🟢', color: 'text-green-600' },
+]
+
+export default function DPRSummaryCards({ summary, sla, loading }: { summary: DPRSummary | null; sla: DPRSla | null; loading: boolean }) {
+  return (
+    <div className="space-y-4 mb-6">
+      <div className="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
+        {CARDS.map((c) => (
+          <div key={c.key} className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4">
+            <div className="text-xs text-zinc-500 mb-1">{c.emoji} {c.label}</div>
+            {loading && !summary ? (
+              <div className="h-7 w-12 bg-black/[0.04] rounded animate-pulse" />
+            ) : (
+              <div className={`text-2xl font-bold ${c.color}`}>{(summary?.[c.key] ?? 0).toLocaleString()}</div>
+            )}
+          </div>
+        ))}
+        <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4">
+          <div className="text-xs text-zinc-500 mb-1">⏱️ Avg Resolution Time</div>
+          {loading && !sla ? (
+            <div className="h-7 w-12 bg-black/[0.04] rounded animate-pulse" />
+          ) : (
+            <div className="text-2xl font-bold text-violet-600">{formatHours(sla?.avgResolutionHours ?? null)}</div>
+          )}
+        </div>
+      </div>
+
+      <div className="grid grid-cols-2 sm:grid-cols-4 gap-4">
+        <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4">
+          <div className="text-xs text-zinc-500 mb-1">🟣 Assigned</div>
+          <div className="text-lg font-bold text-violet-600">{loading && !summary ? '—' : (summary?.assigned ?? 0).toLocaleString()}</div>
+        </div>
+        <div className="bg-red-500/5 border border-red-500/20 rounded-2xl p-4">
+          <div className="text-xs text-zinc-500 mb-1">⚠️ Overdue</div>
+          <div className="text-lg font-bold text-red-500">{loading && !summary ? '—' : (summary?.overdue ?? 0).toLocaleString()}</div>
+        </div>
+        <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4">
+          <div className="text-xs text-zinc-500 mb-1">🏃 Fastest Resolution</div>
+          <div className="text-lg font-bold text-green-600">{loading && !sla ? '—' : formatHours(sla?.fastestResolutionHours ?? null)}</div>
+        </div>
+        <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-4">
+          <div className="text-xs text-zinc-500 mb-1">🐢 Slowest Resolution</div>
+          <div className="text-lg font-bold text-amber-500">{loading && !sla ? '—' : formatHours(sla?.slowestResolutionHours ?? null)}</div>
+        </div>
+      </div>
+    </div>
+  )
+}
