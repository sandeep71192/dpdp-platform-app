-+import type { EventType } from '@/types/database'
-+
-+// Ledger statuses shown in the audit trail — "shown" (widget impression) is
-+// excluded, matching the "Total Consents Collected" definition used elsewhere.
-+export const LEDGER_EVENT_TYPES = ['accepted_all', 'rejected_all', 'customised', 'withdrawn'] as const
-+export type LedgerEventType = typeof LEDGER_EVENT_TYPES[number]
-+
-+export const STATUS_META: Record<LedgerEventType, { label: string; emoji: string }> = {
-+  accepted_all: { label: 'Accepted', emoji: '🟢' },
-+  rejected_all: { label: 'Rejected', emoji: '🔴' },
-+  customised: { label: 'Customized', emoji: '🟡' },
-+  withdrawn: { label: 'Withdrawn', emoji: '⚫' },
-+}
-+
-+export const CONSENT_METHOD_LABELS: Record<EventType, string> = {
-+  shown: 'Widget Displayed',
-+  accepted_all: 'Accepted All',
-+  rejected_all: 'Rejected All',
-+  customised: 'Customized Selection',
-+  withdrawn: 'Consent Withdrawn',
-+}
-+
-+// Derives a stable, human-friendly "DPDP-XXXXXX" display ID from a record's
-+// UUID. This is a one-way display transform (not reversible/searchable as a
-+// number) — the underlying UUID remains the actual lookup key.
-+export function consentDisplayId(id: string): string {
-+  const hex = id.replace(/-/g, '').slice(0, 8)
-+  const num = parseInt(hex, 16) % 1_000_000
-+  return `DPDP-${num.toString().padStart(6, '0')}`
-+}
-+
-+const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i
-+
-+// Resolves a free-text search term into a Supabase filter description.
-+// - Full UUID -> exact match on `id` (covers Consent ID lookups when a user
-+//   pastes the underlying UUID).
-+// - Otherwise -> partial match on `session_id` (the only free-text
-+//   identifier currently stored; `ilike` is unsupported on `uuid` columns so
-+//   partial UUID/session search isn't possible at the DB level).
-+export function resolveSearch(term: string): { column: 'id' | 'session_id'; op: 'eq' | 'ilike'; value: string } | null {
-+  const trimmed = term.trim()
-+  if (!trimmed) return null
-+  if (UUID_RE.test(trimmed)) return { column: 'id', op: 'eq', value: trimmed }
-+  return { column: 'session_id', op: 'ilike', value: `%${trimmed}%` }
-+}
-+
-+export const SORTABLE_COLUMNS = ['created_at', 'event_type', 'language_used'] as const
-+export type SortableColumn = typeof SORTABLE_COLUMNS[number]
-+
-+export function isSortableColumn(value: string): value is SortableColumn {
-+  return (SORTABLE_COLUMNS as readonly string[]).includes(value)
-+}
-+
-+export function isLedgerEventType(value: string): value is LedgerEventType {
-+  return (LEDGER_EVENT_TYPES as readonly string[]).includes(value)
-+}
-+
-+export const PAGE_SIZES = [25, 50, 100] as const
