+export interface LedgerRecord {
+  id: string
+  consentId: string
+  timestamp: string
+  language: string | null
+  status: string
+  statusLabel: string
+  statusEmoji: string
+  purposesAccepted: string[]
+  purposesRejected: string[]
+}
+
+interface SortableHeader {
+  key: string
+  label: string
+  sortable: boolean
+}
+
+const HEADERS: SortableHeader[] = [
+  { key: 'consent_id', label: 'Consent ID', sortable: false },
+  { key: 'created_at', label: 'Timestamp (IST)', sortable: true },
+  { key: 'language_used', label: 'Language', sortable: true },
+  { key: 'event_type', label: 'Status', sortable: true },
+]
+
+interface TableProps {
+  records: LedgerRecord[]
+  loading: boolean
+  sortBy: string
+  sortDir: 'asc' | 'desc'
+  onSort: (col: string) => void
+  selected: Set<string>
+  onToggleSelect: (id: string) => void
+  onToggleSelectAll: () => void
+  onRowClick: (id: string) => void
+}
+
+export default function ConsentLedgerTable({ records, loading, sortBy, sortDir, onSort, selected, onToggleSelect, onToggleSelectAll, onRowClick }: TableProps) {
+  const allSelected = records.length > 0 && records.every((r) => selected.has(r.id))
+
+  if (loading) {
+    return (
+      <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl overflow-hidden">
+        <div className="p-6 space-y-3">
+          {[0, 1, 2, 3, 4].map((i) => (
+            <div key={i} className="h-10 bg-black/[0.04] rounded animate-pulse" />
+          ))}
+        </div>
+      </div>
+    )
+  }
+
+  if (records.length === 0) {
+    return (
+      <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl p-16 text-center">
+        <div className="text-5xl mb-4">📋</div>
+        <h3 className="text-base font-semibold text-[#1b1b29] mb-2">No consent records found</h3>
+        <p className="text-sm text-zinc-500">Try adjusting your filters or date range.</p>
+      </div>
+    )
+  }
+
+  return (
+    <div className="bg-[#ffffff] border border-[#e8e8ee] rounded-2xl overflow-hidden">
+      <div className="overflow-x-auto">
+        <table className="w-full">
+          <thead className="sticky top-0 bg-[#ffffff] z-10">
+            <tr className="border-b border-[#e8e8ee]">
+              <th className="px-5 py-3 w-10">
+                <input type="checkbox" checked={allSelected} onChange={onToggleSelectAll} className="rounded" />
+              </th>
+              {HEADERS.map((h) => (
+                <th
+                  key={h.key}
+                  onClick={() => h.sortable && onSort(h.key)}
+                  className={`text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider px-5 py-3 whitespace-nowrap ${h.sortable ? 'cursor-pointer hover:text-[#1b1b29]' : ''}`}
+                >
+                  {h.label}
+                  {h.sortable && sortBy === h.key && (sortDir === 'asc' ? ' ▲' : ' ▼')}
+                </th>
+              ))}
+            </tr>
+          </thead>
+          <tbody>
+            {records.map((r) => (
+              <tr
+                key={r.id}
+                onClick={() => onRowClick(r.id)}
+                className="border-b border-[#e8e8ee] last:border-0 hover:bg-black/[0.02] cursor-pointer"
+              >
+                <td className="px-5 py-3" onClick={(e) => e.stopPropagation()}>
+                  <input type="checkbox" checked={selected.has(r.id)} onChange={() => onToggleSelect(r.id)} className="rounded" />
+                </td>
+                <td className="px-5 py-3 text-xs font-mono font-semibold text-violet-600 whitespace-nowrap">{r.consentId}</td>
+                <td className="px-5 py-3 text-xs text-zinc-500 font-mono whitespace-nowrap">
+                  {new Date(r.timestamp).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Kolkata' })}
+                </td>
+                <td className="px-5 py-3 text-xs text-zinc-500 uppercase">{r.language || '—'}</td>
+                <td className="px-5 py-3">
+                  <span className="text-xs font-medium">{r.statusEmoji} {r.statusLabel}</span>
+                </td>
+              </tr>
+            ))}
+          </tbody>
+        </table>
+      </div>
+    </div>
+  )
+}
