-+function recordsToTable(rows: ExportRow[], purposeLabel: (id: string) => string) {
-+  return rows.map((r) => {
-+    const purposes = r.consented_to || {}
-+    const accepted = Object.entries(purposes).filter(([, v]) => v).map(([k]) => purposeLabel(k))
-+    const rejected = Object.entries(purposes).filter(([, v]) => !v).map(([k]) => purposeLabel(k))
