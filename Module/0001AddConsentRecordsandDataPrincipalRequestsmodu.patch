+'use client'
+import { useState, useEffect, useCallback } from 'react'
+import { useParams, useRouter } from 'next/navigation'
+import { RangeKey } from '@/components/portal/RangeFilter'
+import Pagination from '@/components/portal/Pagination'
+import ExportMenu from '@/components/portal/ExportMenu'
+import DPRSummaryCards, { DPRSummary, DPRSla } from '@/components/portal/dpr/DPRSummaryCards'
+import DPRFilters, { StatusOption, TypeOption } from '@/components/portal/dpr/DPRFilters'
+import DPRTable, { DPRListItem } from '@/components/portal/dpr/DPRTable'
+import NewRequestModal from '@/components/portal/dpr/NewRequestModal'
+import { PRIORITIES } from '@/lib/dpr-requests'
+import type { DPRPriority } from '@/types/database'
+
+export default function DataPrincipalRequestsPage() {
+  const { clientKey } = useParams<{ clientKey: string }>()
+  const router = useRouter()
+
+  const [range, setRange] = useState<RangeKey>('90d')
+  const [from, setFrom] = useState('')
+  const [to, setTo] = useState('')
+  const [statuses, setStatuses] = useState<string[]>([])
+  const [types, setTypes] = useState<string[]>([])
+  const [priorities, setPriorities] = useState<string[]>([])
+  const [assignedTo, setAssignedTo] = useState('')
+  const [search, setSearch] = useState('')
+  const [sortBy, setSortBy] = useState('created_at')
+  const [sortDir, setSortDir] = useState<'asc' | 'desc'>('desc')
+  const [page, setPage] = useState(1)
+  const [pageSize, setPageSize] = useState(25)
+
+  const [records, setRecords] = useState<DPRListItem[]>([])
+  const [count, setCount] = useState(0)
+  const [summary, setSummary] = useState<DPRSummary | null>(null)
+  const [sla, setSla] = useState<DPRSla | null>(null)
+  const [statusOptions, setStatusOptions] = useState<StatusOption[]>([])
+  const [typeOptions, setTypeOptions] = useState<TypeOption[]>([])
+  const [assignees, setAssignees] = useState<string[]>([])
+  const [loading, setLoading] = useState(true)
+  const [error, setError] = useState<string | null>(null)
+  const [selected, setSelected] = useState<Set<string>>(new Set())
+  const [showNewModal, setShowNewModal] = useState(false)
+
+  const buildParams = useCallback(() => {
+    const params = new URLSearchParams({ key: String(clientKey), range })
+    if (range === 'custom') {
+      if (from) params.set('from', from)
+      if (to) params.set('to', to)
+    }
+    if (statuses.length > 0) params.set('status', statuses.join(','))
+    if (types.length > 0) params.set('type', types.join(','))
+    if (priorities.length > 0) params.set('priority', priorities.join(','))
+    if (assignedTo) params.set('assignedTo', assignedTo)
+    if (search) params.set('search', search)
+    return params
+  }, [clientKey, range, from, to, statuses, types, priorities, assignedTo, search])
+
+  const load = useCallback(() => {
+    const params = buildParams()
+    params.set('sortBy', sortBy)
+    params.set('sortDir', sortDir)
+    params.set('page', String(page))
+    params.set('pageSize', String(pageSize))
+
+    return fetch(`/api/dashboard/dpr-requests?${params.toString()}`)
+      .then((r) => r.json())
+      .then((d) => {
+        if (d.error) throw new Error(d.error)
+        setRecords(d.records)
+        setCount(d.count)
+        setSummary(d.summary)
+        setSla(d.sla)
+        setStatusOptions(d.filters.statuses)
+        setTypeOptions(d.filters.types)
+        setAssignees(d.filters.assignees)
+        setError(null)
+      })
+      .catch(() => setError('Could not load requests. Try again shortly.'))
+      .finally(() => setLoading(false))
+  }, [buildParams, sortBy, sortDir, page, pageSize])
+
+  useEffect(() => {
+    load()
+  }, [load])
+
+  function resetForRefetch() {
+    setLoading(true)
+    setError(null)
+    setSelected(new Set())
+  }
+
+  function handleRangeChange(r: RangeKey, f?: string, t?: string) {
+    const nextFrom = f ?? from
+    setRange(r)
+    if (f !== undefined) setFrom(f)
+    if (t !== undefined) setTo(t)
+    if (r === 'custom' && !nextFrom) return
+    setPage(1)
+    resetForRefetch()
+  }
+
+  function toggleInList(value: string, setter: (fn: (prev: string[]) => string[]) => void) {
+    setter((prev) => (prev.includes(value) ? prev.filter((v) => v !== value) : [...prev, value]))
+    setPage(1)
+    resetForRefetch()
+  }
+
+  function handleAssignedToChange(a: string) {
+    setAssignedTo(a)
+    setPage(1)
+    resetForRefetch()
+  }
+
+  function handleSearchChange(s: string) {
+    setSearch(s)
+    setPage(1)
+    resetForRefetch()
+  }
+
+  function handleSort(col: string) {
+    if (sortBy === col) {
+      setSortDir((d) => (d === 'asc' ? 'desc' : 'asc'))
+    } else {
+      setSortBy(col)
+      setSortDir('desc')
+    }
+    setLoading(true)
+  }
+
+  function handlePageChange(p: number) {
+    setPage(p)
+    setLoading(true)
+  }
+
+  function handlePageSizeChange(size: number) {
+    setPageSize(size)
+    setPage(1)
+    setLoading(true)
+  }
+
+  function toggleSelect(id: string) {
+    setSelected((prev) => {
+      const next = new Set(prev)
+      if (next.has(id)) next.delete(id)
+      else next.add(id)
+      return next
+    })
+  }
+
+  function toggleSelectAll() {
+    setSelected((prev) => {
+      if (records.every((r) => prev.has(r.id))) return new Set()
+      return new Set(records.map((r) => r.id))
+    })
+  }
+
+  function handleCreated() {
+    setShowNewModal(false)
+    resetForRefetch()
+    load()
+  }
+
+  return (
+    <div className="p-8">
+      <div className="mb-6 flex items-start justify-between gap-4 flex-wrap">
+        <div>
+          <h1 className="text-2xl font-bold text-[#1b1b29] tracking-tight">Data Principal Requests</h1>
+          <p className="text-sm text-zinc-500 mt-1">Receive, track and resolve access, correction, deletion and data-removal requests under the DPDP Act</p>
+        </div>
+        <div className="flex items-center gap-2">
+          <button onClick={() => setShowNewModal(true)} className="px-4 py-2.5 bg-black/[0.04] hover:bg-black/[0.08] text-[#1b1b29] text-sm font-semibold rounded-xl transition-colors">
+            + Log Request
+          </button>
+          <ExportMenu
+            clientKey={String(clientKey)}
+            exportPath="/api/dashboard/dpr-requests/export"
+            baseParams={buildParams()}
+            selectedCount={selected.size}
+            buildSelectedIds={() => Array.from(selected)}
+            scopes={[
+              { value: 'filtered', label: 'Current Filters' },
+              { value: 'selected', label: `Selected Requests (${selected.size})` },
+              { value: 'all', label: 'All Requests' },
+            ]}
+          />
+        </div>
+      </div>
+
+      {error && (
+        <div className="bg-red-500/5 border border-red-500/20 rounded-2xl p-4 mb-6 text-sm text-red-500">{error}</div>
+      )}
+
+      <DPRSummaryCards summary={summary} sla={sla} loading={loading} />
+
+      <DPRFilters
+        range={range} from={from} to={to} onRangeChange={handleRangeChange}
+        statusOptions={statusOptions} selectedStatuses={statuses} onStatusToggle={(v) => toggleInList(v, setStatuses)}
+        typeOptions={typeOptions} selectedTypes={types} onTypeToggle={(v) => toggleInList(v, setTypes)}
+        priorities={PRIORITIES as DPRPriority[]} selectedPriorities={priorities} onPriorityToggle={(v) => toggleInList(v, setPriorities)}
+        assignees={assignees} assignedTo={assignedTo} onAssignedToChange={handleAssignedToChange}
+        search={search} onSearchChange={handleSearchChange}
+      />
+
+      <DPRTable
+        records={records}
+        loading={loading}
+        sortBy={sortBy}
+        sortDir={sortDir}
+        onSort={handleSort}
+        selected={selected}
+        onToggleSelect={toggleSelect}
+        onToggleSelectAll={toggleSelectAll}
+        onRowClick={(id) => router.push(`/portal/${clientKey}/requests/${id}`)}
+      />
+
+      {!loading && records.length > 0 && (
+        <Pagination page={page} pageSize={pageSize} count={count} onPageChange={handlePageChange} onPageSizeChange={handlePageSizeChange} />
+      )}
+
+      {showNewModal && (
+        <NewRequestModal clientKey={String(clientKey)} onClose={() => setShowNewModal(false)} onCreated={handleCreated} />
+      )}
+    </div>
+  )
+}
